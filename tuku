OLLAMA_STATUS="" OLLAMA_MODELS_JSON="" OLLAMA_MODEL_COUNT=0
OLLAMA_MODELS_DISPLAY=()

fetch_ollama() {
    local response
    response="$(curl -s --connect-timeout 0.5 --max-time 1 http://localhost:11434/api/ps 2>/dev/null)" || response=""
    if [[ -z "${response}" ]]; then
        OLLAMA_STATUS="down"
        return
    fi
    OLLAMA_STATUS="running"
    OLLAMA_MODELS_JSON="${response}"

    OLLAMA_MODEL_COUNT="$(printf '%s' "${response}" | grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | wc -l)" || OLLAMA_MODEL_COUNT=0

    local names sizes expires
    mapfile -t names < <(printf '%s' "${response}" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' 2>/dev/null || true)
    mapfile -t sizes < <(printf '%s' "${response}" | sed -n 's/.*"size"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' 2>/dev/null || true)
    mapfile -t expires < <(printf '%s' "${response}" | sed -n 's/.*"expires_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' 2>/dev/null || true)

    OLLAMA_MODELS_DISPLAY=()
    local now_epoch
    now_epoch="$(date +%s)"
    for i in "${!names[@]}"; do
        local name="${names[$i]}"
        local size="${sizes[$i]:-0}"
        local expire="${expires[$i]:-}"

        local size_gb=0
        if [[ ${size} -gt 0 ]]; then
            size_gb=$(( size / 1073741824 ))
            [[ ${size_gb} -eq 0 ]] && size_gb=1
        fi

        local until_str=""
        if [[ -n "${expire}" ]]; then
            local expire_epoch
            expire_epoch="$(date -d "${expire}" +%s 2>/dev/null)" || expire_epoch=0
            if [[ ${expire_epoch} -gt 0 ]]; then
                local remaining=$(( expire_epoch - now_epoch ))
                if [[ ${remaining} -gt 0 ]]; then
                    local remain_min=$(( remaining / 60 ))
                    until_str="until ${remain_min}m"
                else
                    until_str="expiring"
                fi
            fi
        fi

        local display="${name} (${size_gb} GB"
        if [[ -n "${until_str}" ]]; then
            display+=", ${until_str}"
        fi
        display+=")"
        OLLAMA_MODELS_DISPLAY+=("${display}")
    done
}

render_ollama() {
    print_header "Ollama"
    if [[ "${OLLAMA_STATUS}" == "down" ]]; then
        printf '  %b%-8s%b %b● down%b\n' \
            "${BOLD_WHITE}" "Status" "${RESET}" "${RED}" "${RESET}"
        return
    fi

    local status_color="${GREEN}"
    printf '  %b%-8s%b %b● running%b (%s models loaded) · http://localhost:11434/\n' \
        "${BOLD_WHITE}" "Status" "${RESET}" "${status_color}" "${RESET}" "${OLLAMA_MODEL_COUNT}"

    if [[ ${OLLAMA_MODEL_COUNT} -gt 0 ]] && [[ ${#OLLAMA_MODELS_DISPLAY[@]} -gt 0 ]]; then
        printf '  %b%-8s%b %b%s%b\n' \
            "${BOLD_WHITE}" "Active" "${RESET}" "${CYAN}" "${OLLAMA_MODELS_DISPLAY[0]}" "${RESET}"
        for ((i = 1; i < ${#OLLAMA_MODELS_DISPLAY[@]}; i++)); do
            printf '           %b%s%b\n' "${CYAN}" "${OLLAMA_MODELS_DISPLAY[$i]}" "${RESET}"
        done
    fi
}

# ---------- Reaper status for dashboard ----------

# Determine reaper countdown status for a llama.cpp process.
# Reads .alive files from BOTH system and user state dirs (read-only).
# Returns: "status_text|color_var"
#   - "-"             (dim)    → reaper not installed
#   - "safe Xm"       (green)  → process younger than min_age
#   - "active"         (green)  → eligible, .alive recent
#   - "expires soon"   (red)    → eligible, .alive old
#   - "monitoring"     (yellow) → eligible, no .alive file
get_reaper_status_for_pid() {
    local pid="$1" uptime_seconds="$2"

    # If reaper is not installed, show "-"
    if [[ "${REAPER_STATUS}" != "active" ]]; then
        echo "-|dim"
        return
    fi

    local min_age="${REAPER_MIN_AGE:-60}"
    local max_idle="${REAPER_MAX_IDLE:-30}"
    local process_age_minutes=$(( uptime_seconds / 60 ))

    # Process younger than min_age — safe
    if [[ ${process_age_minutes} -lt ${min_age} ]]; then
        local remaining=$(( min_age - process_age_minutes ))
        echo "safe ${remaining}m|green"
        return
    fi

    # If GPU power > 100W, treat as active regardless
    if [[ "${GPU_POWER_ACTIVE}" == true ]]; then
        echo "active|green"
        return
    fi

    # Process is eligible — check .alive files
    local alive_ts=""
    local system_alive="/var/lib/tuku/reaper/${pid}.alive"
    local user_alive="${HOME}/.local/state/tuku/reaper/${pid}.alive"

    # Check system mode first, then user mode (handle permission denied gracefully)
    if [[ -f "${system_alive}" ]] && [[ -r "${system_alive}" ]]; then
        alive_ts="$(cat "${system_alive}" 2>/dev/null)" || alive_ts=""
    fi
    if [[ -z "${alive_ts}" ]] && [[ -f "${user_alive}" ]] && [[ -r "${user_alive}" ]]; then
        alive_ts="$(cat "${user_alive}" 2>/dev/null)" || alive_ts=""
    fi

    if [[ -n "${alive_ts}" ]] && [[ "${alive_ts}" =~ ^[0-9]+$ ]]; then
        local now
        now="$(date +%s)"
        local idle_seconds=$(( now - alive_ts ))
        local max_idle_seconds=$(( max_idle * 60 ))
        if [[ ${idle_seconds} -lt ${max_idle_seconds} ]]; then
            echo "active|green"
        else
            echo "expires soon|red"
        fi
    else
        # No .alive file — reaper hasn't assessed yet
        echo "monitoring|yellow"
    fi
}

# ---------- llama.cpp display ----------

DASH_LLAMA_PIDS=()
DASH_LLAMA_USERS=()
DASH_LLAMA_VRAMS=()
DASH_LLAMA_MODELS=()
DASH_LLAMA_PORTS=()
DASH_LLAMA_UPTIMES=()
DASH_LLAMA_STATUSES=()
DASH_LLAMA_STATUS_COLORS=()

# Dashboard-specific process discovery (uses cached GPU data, API fallbacks)
find_llama_for_dashboard() {
    # Pre-filter: single awk pass extracts matching lines only
    local filtered
    filtered="$(ps -eo pid=,user=,args= 2>/dev/null | awk -v pattern="${LLAMA_PATTERN}" -v excluded="${EXCLUDED_BASENAMES}" '
{
    cmd = $3
    n = split(cmd, parts, "/")
    exe = parts[n]
    if (match(exe, excluded)) next
    if (match(exe, pattern)) print $0
}
')" || return 0

    [[ -z "${filtered}" ]] && return 0

    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue

        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        [[ "${pid}" == "$$" ]] && continue

        DASH_LLAMA_PIDS+=("${pid}")
        DASH_LLAMA_USERS+=("${user}")

        # VRAM from cached nvidia-smi data
        local vram
        vram="$(get_vram_for_pid "${pid}")"
        if [[ -n "${vram}" ]] && [[ "${vram}" != "0" ]]; then
            DASH_LLAMA_VRAMS+=("$(mib_to_gb "${vram}")")
        else
            DASH_LLAMA_VRAMS+=("-")
        fi

        # Port: try args first, then ss
        local port
        port="$(get_listen_port "${pid}" "${args}")"

        # Model: try args first, then API
        local model
        model="$(get_model_name "${pid}" "${args}" "${port}")"

        DASH_LLAMA_MODELS+=("${model}")
        DASH_LLAMA_PORTS+=("${port:-"-"}")

        # Uptime
        local uptime_sec
        uptime_sec="$(get_process_uptime_seconds "${pid}")"
        if [[ ${uptime_sec} -gt 0 ]]; then
            DASH_LLAMA_UPTIMES+=("$(format_uptime "${uptime_sec}")")
        else
            DASH_LLAMA_UPTIMES+=("-")
        fi

        # Reaper status (read-only — no side effects)
        local status_result status_text status_color
        status_result="$(get_reaper_status_for_pid "${pid}" "${uptime_sec}")"
        status_text="${status_result%%|*}"
        status_color="${status_result##*|}"
        DASH_LLAMA_STATUSES+=("${status_text}")
        DASH_LLAMA_STATUS_COLORS+=("${status_color}")
    done <<< "${filtered}"
}

render_llama() {
    print_header "llama.cpp"
    if [[ ${#DASH_LLAMA_PIDS[@]} -eq 0 ]]; then
        printf '  No active processes\n'
        return
    fi

    printf '  %b%-8s %-8s %-8s %-24s %-7s %-13s %s%b\n' \
        "${BOLD_WHITE}" "PID" "USER" "VRAM" "ENDPOINT" "UPTIME" "STATUS" "MODEL" "${RESET}"

    for i in "${!DASH_LLAMA_PIDS[@]}"; do
        local endpoint="${DASH_LLAMA_PORTS[$i]}"
        if [[ "${endpoint}" != "-" ]]; then
            endpoint="http://localhost:${endpoint}/"
        fi

        # Map status color name to ANSI variable
        local sc=""
        case "${DASH_LLAMA_STATUS_COLORS[$i]}" in
            green)  sc="${GREEN}" ;;
            red)    sc="${RED}" ;;
            yellow) sc="${YELLOW}" ;;
            *)      sc="${CYAN}" ;;   # dim/"−" uses default
        esac

        printf '  %b%-8s%b %b%-8s%b %b%-8s%b %b%-24s%b %b%-7s%b %b%-13s%b %b%s%b\n' \
            "${CYAN}" "${DASH_LLAMA_PIDS[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_USERS[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_VRAMS[$i]}" "${RESET}" \
            "${CYAN}" "${endpoint}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_UPTIMES[$i]}" "${RESET}" \
            "${sc}" "${DASH_LLAMA_STATUSES[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_MODELS[$i]}" "${RESET}"
    done
}

