BOLD_WHITE='\033[1;37m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
DIM_GRAY='\033[90m'
RESET='\033[0m'
USE_COLOR=true

# Print colored text
c() {
    local color="$1" text="$2"
    printf '%b%s%b' "${color}" "${text}" "${RESET}"
}

# ---------- Display helpers ----------

# Section header: ─── Title ─────────────────────────
print_header() {
    local title="$1"
    local total_width=49
    local pre_len=4  # "─── " is 4 chars visually
    local title_len=${#title}
    local space=1
    local fill_len=$(( total_width - pre_len - title_len - space ))
    [[ ${fill_len} -lt 1 ]] && fill_len=1
    local fill=""
    for ((i = 0; i < fill_len; i++)); do
        fill+="─"
    done
    printf '%b─── %s %s%b\n' "${DIM_GRAY}" "${title}" "${fill}" "${RESET}"
}

# Progress bar: current, max, width → ━━━━━━━─── XX%
progress_bar() {
    local current="$1" max="$2" width="${3:-15}"
    local pct=0
    if [[ ${max} -gt 0 ]]; then
        pct=$(( current * 100 / max ))
    fi
    local filled=$(( current * width / (max > 0 ? max : 1) ))
    [[ ${filled} -gt ${width} ]] && filled=${width}
    local empty=$(( width - filled ))
    local bar=""
    for ((i = 0; i < filled; i++)); do
        bar+="━"
    done
    for ((i = 0; i < empty; i++)); do
        bar+="─"
    done

    local bar_color="${GREEN}"
    if [[ ${pct} -ge 90 ]]; then
        bar_color="${RED}"
    elif [[ ${pct} -ge 70 ]]; then
        bar_color="${YELLOW}"
    fi

    printf '%b%s%b %s%%' "${bar_color}" "${bar}" "${RESET}" "${pct}"
}

# Label + value helper
label_val() {
    local label="$1" value="$2"
    printf '  %b%-8s%b %b%s%b\n' "${BOLD_WHITE}" "${label}" "${RESET}" "${CYAN}" "${value}" "${RESET}"
}

# ---------- GPU dashboard ----------

GPU_INFO=""
GPU_PROCS=""
GPU_AVAILABLE=false
declare -A GPU_VRAM_BY_PID

cache_gpu_data() {
    if command -v nvidia-smi &>/dev/null; then
        GPU_INFO="$(nvidia-smi --query-gpu=name,memory.used,memory.total,temperature.gpu,power.draw,power.limit,utilization.gpu --format=csv,noheader,nounits 2>/dev/null)" || GPU_INFO=""
        GPU_PROCS="$(nvidia-smi --query-compute-apps=pid,used_gpu_memory --format=csv,noheader,nounits 2>/dev/null)" || GPU_PROCS=""
        if [[ -n "${GPU_INFO}" ]]; then
            GPU_AVAILABLE=true
        fi
        # Build associative array for O(1) VRAM lookups per PID
        GPU_VRAM_BY_PID=()
        if [[ -n "${GPU_PROCS}" ]]; then
            while IFS= read -r _line; do
                [[ -z "${_line}" ]] && continue
                local _pid _mem
                _pid="${_line%%,*}"
                _mem="${_line#*,}"
                _pid="${_pid#"${_pid%%[! ]*}"}"  # trim leading spaces
                _mem="${_mem#"${_mem%%[! ]*}"}"  # trim leading spaces
                _mem="${_mem%%[[:space:]]*}"     # trim trailing spaces
                [[ -n "${_pid}" ]] && GPU_VRAM_BY_PID["${_pid}"]="${_mem}"
            done <<< "${GPU_PROCS}"
        fi
    fi
}

get_vram_for_pid() {
    local target_pid="$1"
    echo "${GPU_VRAM_BY_PID[${target_pid}]:-}"
}

GPU_NAME="" GPU_MEM_USED=0 GPU_MEM_TOTAL=0 GPU_TEMP=0
GPU_POWER_DRAW=0 GPU_POWER_LIMIT=0 GPU_UTIL=0

parse_gpu_info() {
    [[ "${GPU_AVAILABLE}" != true ]] && return 1
    IFS=',' read -r _name _mem_used _mem_total _temp _pow_draw _pow_limit _util <<< "${GPU_INFO}"
    GPU_NAME="$(echo "${_name}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    GPU_MEM_USED="$(echo "${_mem_used}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_MEM_TOTAL="$(echo "${_mem_total}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_TEMP="$(echo "${_temp}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_POWER_DRAW="$(echo "${_pow_draw}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_POWER_LIMIT="$(echo "${_pow_limit}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_UTIL="$(echo "${_util}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    return 0
}

render_gpu() {
    print_header "GPU"
    if [[ "${GPU_AVAILABLE}" != true ]]; then
        printf '  %b%s%b\n' "${RED}" "nvidia-smi not available" "${RESET}"
        return
    fi
    parse_gpu_info || return

    label_val "GPU" "${GPU_NAME}"

    local vram_bar
    vram_bar="$(progress_bar "${GPU_MEM_USED}" "${GPU_MEM_TOTAL}" 15)"
    local vram_used_gb vram_total_gb
    vram_used_gb="$(mib_to_gb "${GPU_MEM_USED}")"
    vram_total_gb="$(mib_to_gb "${GPU_MEM_TOTAL}")"
    printf '  %b%-8s%b %b%s / %s%b  %s\n' \
        "${BOLD_WHITE}" "VRAM" "${RESET}" \
        "${CYAN}" "${vram_used_gb}" "${vram_total_gb}" "${RESET}" \
        "${vram_bar}"

    local temp_color="${GREEN}"
    if [[ ${GPU_TEMP} -ge 80 ]]; then
        temp_color="${RED}"
    elif [[ ${GPU_TEMP} -ge 65 ]]; then
        temp_color="${YELLOW}"
    fi

    local util_color="${CYAN}"

    printf '  %b%-8s%b %b%s°C%b    %b%-8s%b %b%sW / %sW%b    %b%-6s%b %b%s%%%b\n' \
        "${BOLD_WHITE}" "Temp" "${RESET}" "${temp_color}" "${GPU_TEMP}" "${RESET}" \
        "${BOLD_WHITE}" "Power" "${RESET}" "${CYAN}" "${GPU_POWER_DRAW}" "${GPU_POWER_LIMIT}" "${RESET}" \
        "${BOLD_WHITE}" "Util" "${RESET}" "${util_color}" "${GPU_UTIL}" "${RESET}"
}

# ---------- Ollama ----------

OLLAMA_STATUS="" OLLAMA_MODELS_JSON="" OLLAMA_MODEL_COUNT=0
OLLAMA_MODELS_DISPLAY=()

fetch_ollama() {
    local response
    response="$(curl -s --connect-timeout 0.5 --max-time 1 http://localhost:11434/api/ps 2>/dev/null)" || response=""
    if [[ -z "${response}" ]]; then
        OLLAMA_STATUS="down"
        return
    fi
    OLLAMA_STATUS="running"
    OLLAMA_MODELS_JSON="${response}"

    OLLAMA_MODEL_COUNT="$(printf '%s' "${response}" | grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | wc -l)" || OLLAMA_MODEL_COUNT=0

    local names sizes expires
    mapfile -t names < <(printf '%s' "${response}" | sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' 2>/dev/null || true)
    mapfile -t sizes < <(printf '%s' "${response}" | sed -n 's/.*"size"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' 2>/dev/null || true)
    mapfile -t expires < <(printf '%s' "${response}" | sed -n 's/.*"expires_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' 2>/dev/null || true)

    OLLAMA_MODELS_DISPLAY=()
    local now_epoch
    now_epoch="$(date +%s)"
    for i in "${!names[@]}"; do
        local name="${names[$i]}"
        local size="${sizes[$i]:-0}"
        local expire="${expires[$i]:-}"

        local size_gb=0
        if [[ ${size} -gt 0 ]]; then
            size_gb=$(( size / 1073741824 ))
            [[ ${size_gb} -eq 0 ]] && size_gb=1
        fi

        local until_str=""
        if [[ -n "${expire}" ]]; then
            local expire_epoch
            expire_epoch="$(date -d "${expire}" +%s 2>/dev/null)" || expire_epoch=0
            if [[ ${expire_epoch} -gt 0 ]]; then
                local remaining=$(( expire_epoch - now_epoch ))
                if [[ ${remaining} -gt 0 ]]; then
                    local remain_min=$(( remaining / 60 ))
                    until_str="until ${remain_min}m"
                else
                    until_str="expiring"
                fi
            fi
        fi

        local display="${name} (${size_gb} GB"
        if [[ -n "${until_str}" ]]; then
            display+=", ${until_str}"
        fi
        display+=")"
        OLLAMA_MODELS_DISPLAY+=("${display}")
    done
}

render_ollama() {
    print_header "Ollama"
    if [[ "${OLLAMA_STATUS}" == "down" ]]; then
        printf '  %b%-8s%b %b● down%b\n' \
            "${BOLD_WHITE}" "Status" "${RESET}" "${RED}" "${RESET}"
        return
    fi

    local status_color="${GREEN}"
    printf '  %b%-8s%b %b● running%b (%s models loaded) · http://localhost:11434/\n' \
        "${BOLD_WHITE}" "Status" "${RESET}" "${status_color}" "${RESET}" "${OLLAMA_MODEL_COUNT}"

    if [[ ${OLLAMA_MODEL_COUNT} -gt 0 ]] && [[ ${#OLLAMA_MODELS_DISPLAY[@]} -gt 0 ]]; then
        printf '  %b%-8s%b %b%s%b\n' \
            "${BOLD_WHITE}" "Active" "${RESET}" "${CYAN}" "${OLLAMA_MODELS_DISPLAY[0]}" "${RESET}"
        for ((i = 1; i < ${#OLLAMA_MODELS_DISPLAY[@]}; i++)); do
            printf '           %b%s%b\n' "${CYAN}" "${OLLAMA_MODELS_DISPLAY[$i]}" "${RESET}"
        done
    fi
}

# ---------- Reaper status for dashboard ----------

# Determine reaper status for a llama.cpp process.
# Reads .alive files from BOTH system and user state dirs (read-only).
# Returns: "status_text|color_var"
#   - "-"             (dim)    → reaper not installed
#   - "fresh"         (green)  → process younger than min_age
#   - "active"        (yellow) → eligible, .alive recent (within 2 min)
#   - "inactive"      (green)  → eligible, .alive older than 2 min but idle < max_idle
#   - "stale Xm"      (red)   → eligible, approaching or past max_idle (X = min remaining)
get_reaper_status_for_pid() {
    local pid="$1" uptime_seconds="$2"

    # If reaper is not installed, show "-"
    if [[ "${REAPER_STATUS}" != "active" ]]; then
        echo "-|dim"
        return
    fi

    local min_age="${REAPER_MIN_AGE:-60}"
    local max_idle="${REAPER_MAX_IDLE:-30}"
    local process_age_minutes=$(( uptime_seconds / 60 ))

    # Process younger than min_age — fresh
    if [[ ${process_age_minutes} -lt ${min_age} ]]; then
        echo "fresh|green"
        return
    fi

    # Process is eligible — check .alive files
    local alive_ts=""
    local system_alive="/var/lib/tuku/reaper/${pid}.alive"
    local user_alive="${HOME}/.local/state/tuku/reaper/${pid}.alive"

    # Check system mode first, then user mode (handle permission denied gracefully)
    if [[ -f "${system_alive}" ]] && [[ -r "${system_alive}" ]]; then
        alive_ts="$(cat "${system_alive}" 2>/dev/null)" || alive_ts=""
    fi
    if [[ -z "${alive_ts}" ]] && [[ -f "${user_alive}" ]] && [[ -r "${user_alive}" ]]; then
        alive_ts="$(cat "${user_alive}" 2>/dev/null)" || alive_ts=""
    fi

    # No .alive file or unreadable — reaper hasn't assessed yet, benefit of doubt
    if [[ -z "${alive_ts}" ]] || ! [[ "${alive_ts}" =~ ^[0-9]+$ ]]; then
        echo "inactive|dim"
        return
    fi

    local now
    now="$(date +%s)"
    local idle_seconds=$(( now - alive_ts ))

    # Active within last 2 minutes
    if [[ ${idle_seconds} -lt 120 ]]; then
        echo "active|yellow"
        return
    fi

    # Process has been idle for a while — check remaining time until kill
    local idle_minutes=$(( idle_seconds / 60 ))
    local remaining=$(( max_idle - idle_minutes ))

    if [[ ${remaining} -gt 5 ]]; then
        echo "inactive|dim"
    elif [[ ${remaining} -gt 0 ]]; then
        echo "stale ${remaining}m|red"
    else
        echo "stale 0m|red"
    fi
}

# ---------- llama.cpp display ----------

DASH_LLAMA_PIDS=()
DASH_LLAMA_USERS=()
DASH_LLAMA_VRAMS=()
DASH_LLAMA_MODELS=()
DASH_LLAMA_PORTS=()
DASH_LLAMA_UPTIMES=()
DASH_LLAMA_STATUSES=()
DASH_LLAMA_STATUS_COLORS=()

# Dashboard-specific process discovery (uses cached GPU data, API fallbacks)
find_llama_for_dashboard() {
    local process_lines
    process_lines="$(discover_llama_processes)"
    [[ -z "${process_lines}" ]] && return 0

    while IFS= read -r proc_line; do
        [[ -z "${proc_line}" ]] && continue

        local pid user args
        pid="$(echo "${proc_line}" | awk '{print $1}')"
        user="$(echo "${proc_line}" | awk '{print $2}')"
        args="$(echo "${proc_line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        DASH_LLAMA_PIDS+=("${pid}")
        DASH_LLAMA_USERS+=("${user}")

        # VRAM from cached nvidia-smi data
        local vram
        vram="$(get_vram_for_pid "${pid}")"
        if [[ -n "${vram}" ]] && [[ "${vram}" != "0" ]]; then
            DASH_LLAMA_VRAMS+=("$(mib_to_gb "${vram}")")
        else
            DASH_LLAMA_VRAMS+=("-")
        fi

        # Port: try args first, then ss
        local port
        port="$(get_listen_port "${pid}" "${args}")"

        # Model: try args first, then API
        local model
        model="$(get_model_name "${pid}" "${args}" "${port}")"

        DASH_LLAMA_MODELS+=("${model}")
        DASH_LLAMA_PORTS+=("${port:-"-"}")

        # Uptime
        local uptime_sec
        uptime_sec="$(get_process_uptime_seconds "${pid}")"
        if [[ ${uptime_sec} -gt 0 ]]; then
            DASH_LLAMA_UPTIMES+=("$(format_uptime "${uptime_sec}")")
        else
            DASH_LLAMA_UPTIMES+=("-")
        fi

        # Reaper status (read-only — no side effects)
        local status_result status_text status_color
        status_result="$(get_reaper_status_for_pid "${pid}" "${uptime_sec}")"
        status_text="${status_result%%|*}"
        status_color="${status_result##*|}"
        DASH_LLAMA_STATUSES+=("${status_text}")
        DASH_LLAMA_STATUS_COLORS+=("${status_color}")
    done <<< "${process_lines}"
}

# ── Find non-llama, non-ollama GPU processes for dashboard ───────────

DASH_OTHER_PIDS=()
DASH_OTHER_USERS=()
DASH_OTHER_VRAMS=()
DASH_OTHER_CMDS=()
DASH_OTHER_UPTIMES=()

find_other_gpu_for_dashboard() {
    # Reset arrays
    DASH_OTHER_PIDS=()
    DASH_OTHER_USERS=()
    DASH_OTHER_VRAMS=()
    DASH_OTHER_CMDS=()
    DASH_OTHER_UPTIMES=()

    # Need GPU_VRAM_BY_PID from cache_gpu_data
    [[ ${#GPU_VRAM_BY_PID[@]} -eq 0 ]] && return 0

    local pid
    for pid in "${!GPU_VRAM_BY_PID[@]}"; do
        # Skip if already shown in llama.cpp section
        local is_llama_pid=false
        local lp
        for lp in "${DASH_LLAMA_PIDS[@]}"; do
            if [[ "${lp}" == "${pid}" ]]; then
                is_llama_pid=true
                break
            fi
        done
        [[ "${is_llama_pid}" == true ]] && continue

        # Skip if process no longer exists
        kill -0 "${pid}" 2>/dev/null || continue

        # Get process info
        local ps_info
        ps_info="$(ps -p "${pid}" -o user=,etimes=,args= 2>/dev/null)" || continue
        [[ -z "${ps_info}" ]] && continue

        local user elapsed_secs cmdline
        user="$(echo "${ps_info}" | awk '{print $1}')"
        elapsed_secs="$(echo "${ps_info}" | awk '{print $2}')"
        cmdline="$(echo "${ps_info}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        # Classify — skip ollama
        local exe_basename
        exe_basename="$(echo "${cmdline}" | awk '{n=split($1,a,"/"); print a[n]}')"
        if is_ollama_process "${exe_basename}"; then
            continue
        fi

        DASH_OTHER_PIDS+=("${pid}")
        DASH_OTHER_USERS+=("${user}")

        local vram="${GPU_VRAM_BY_PID[${pid}]}"
        if [[ -n "${vram}" ]] && [[ "${vram}" != "0" ]]; then
            DASH_OTHER_VRAMS+=("$(mib_to_gb "${vram}")")
        else
            DASH_OTHER_VRAMS+=("-")
        fi

        # Truncate command
        local cmd_display="${cmdline}"
        if [[ ${#cmd_display} -gt 50 ]]; then
            cmd_display="${cmd_display:0:47}..."
        fi
        DASH_OTHER_CMDS+=("${cmd_display}")

        if [[ ${elapsed_secs} -gt 0 ]]; then
            DASH_OTHER_UPTIMES+=("$(format_uptime "${elapsed_secs}")")
        else
            DASH_OTHER_UPTIMES+=("-")
        fi
    done
}

render_llama() {
    print_header "llama.cpp"
    if [[ ${#DASH_LLAMA_PIDS[@]} -eq 0 ]]; then
        printf '  No active processes\n'
        return
    fi

    printf '  %b%-8s %-8s %-8s %-24s %-7s %-13s %s%b\n' \
        "${BOLD_WHITE}" "PID" "USER" "VRAM" "ENDPOINT" "UPTIME" "STATUS" "MODEL" "${RESET}"

    for i in "${!DASH_LLAMA_PIDS[@]}"; do
        local endpoint="${DASH_LLAMA_PORTS[$i]}"
        if [[ "${endpoint}" != "-" ]]; then
            endpoint="http://localhost:${endpoint}/"
        fi

        # Map status color name to ANSI variable
        local sc=""
        case "${DASH_LLAMA_STATUS_COLORS[$i]}" in
            green)  sc="${GREEN}" ;;
            red)    sc="${RED}" ;;
            yellow) sc="${YELLOW}" ;;
            dim)    sc="${DIM_GRAY}" ;;
            *)      sc="${CYAN}" ;;
        esac

        printf '  %b%-8s%b %b%-8s%b %b%-8s%b %b%-24s%b %b%-7s%b %b%-13s%b %b%s%b\n' \
            "${CYAN}" "${DASH_LLAMA_PIDS[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_USERS[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_VRAMS[$i]}" "${RESET}" \
            "${CYAN}" "${endpoint}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_UPTIMES[$i]}" "${RESET}" \
            "${sc}" "${DASH_LLAMA_STATUSES[$i]}" "${RESET}" \
            "${CYAN}" "${DASH_LLAMA_MODELS[$i]}" "${RESET}"
    done
}

# ---------- Reaper config display ----------

REAPER_STATUS="" REAPER_INTERVAL="" REAPER_MIN_AGE="" REAPER_MAX_IDLE=""

fetch_reaper() {
    local cron_file="/etc/cron.d/tuku"
    if [[ -f "${cron_file}" ]]; then
        REAPER_STATUS="active"
        REAPER_INTERVAL="$(sed -n 's/^\*\/\([0-9]\+\).*/\1/p' "${cron_file}" 2>/dev/null | head -1)" || REAPER_INTERVAL=""
        REAPER_MIN_AGE="$(sed -n 's/.*--min-age[[:space:]]\+\([0-9]\+\).*/\1/p' "${cron_file}" 2>/dev/null | head -1)" || REAPER_MIN_AGE=""
        REAPER_MAX_IDLE="$(sed -n 's/.*--max-idle[[:space:]]\+\([0-9]\+\).*/\1/p' "${cron_file}" 2>/dev/null | head -1)" || REAPER_MAX_IDLE=""
        return
    fi

    local user_cron
    user_cron="$(crontab -l 2>/dev/null)" || user_cron=""
    if echo "${user_cron}" | grep -q "tuku"; then
        REAPER_STATUS="active"
        REAPER_INTERVAL="$(echo "${user_cron}" | grep "tuku" | sed -n 's/^\*\/\([0-9]\+\).*/\1/p' | head -1)" || REAPER_INTERVAL=""
        REAPER_MIN_AGE="$(echo "${user_cron}" | grep "tuku" | sed -n 's/.*--min-age[[:space:]]\+\([0-9]\+\).*/\1/p' | head -1)" || REAPER_MIN_AGE=""
        REAPER_MAX_IDLE="$(echo "${user_cron}" | grep "tuku" | sed -n 's/.*--max-idle[[:space:]]\+\([0-9]\+\).*/\1/p' | head -1)" || REAPER_MAX_IDLE=""
        return
    fi

    REAPER_STATUS="not installed"
}

