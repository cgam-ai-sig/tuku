#!/usr/bin/env bash
set -euo pipefail

# tuku — watchdog that detects and kills idle llama.cpp processes
# Last-ditch safety net for shared GPU servers.
#
# Two modes:
#   User mode (default): manages only current user's processes
#   System mode (--system): manages ALL users' processes (needs root for install)
#
# Usage: tuku [--min-age MINUTES] [--max-idle MINUTES] [--dry-run] [--verbose] [--force]
#        tuku list
#        tuku install [--system] [--interval MINUTES]
#        tuku uninstall [--system]

readonly VERSION="1.0.0"
readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_PATH="$(readlink -f "$0")"
USER_STATE_DIR="${HOME}/.local/state/tuku"
REAPER_STATE_DIR="${USER_STATE_DIR}/reaper"
readonly USER_LOG="${USER_STATE_DIR}/reaper.log"
readonly SYSTEM_LOG="/var/log/tuku.log"
readonly CRON_MARKER="# tuku-managed"
readonly SYSTEM_CRON_FILE="/etc/cron.d/tuku"

# Llama process name patterns (extended regex for grep -E)
readonly LLAMA_PATTERN='llama-server|llama-cli|llama-cpp|llama\.cpp'

# Scoring threshold — single threshold, kill if idle long enough
readonly SCORE_KILL=8

# Defaults
MIN_AGE_MINUTES=60
MAX_IDLE_MINUTES=30
DRY_RUN=false
VERBOSE=false
FORCE=false
SYSTEM_MODE=false

# ---------- Usage / Help ----------

usage() {
    cat <<'EOF'
Usage: tuku [OPTIONS] [COMMAND]

Watchdog that detects and kills idle llama.cpp processes.

Commands:
  list                     Show all llama.cpp processes with idle scores
  install [OPTIONS]        Install as a recurring cron job
  uninstall [OPTIONS]      Remove the cron job

Options (main / default command):
  --min-age MINUTES        Minimum age (minutes) for a process to be eligible
                           for reaping. Processes younger than this are ignored
                           entirely. (default: 60)
  --max-idle MINUTES       How many continuous minutes a process must score as
                           idle before it is killed. (default: 30)
  --dry-run                Show what would happen without killing anything
  --verbose                Show detailed idle scoring for each process
  --force                  Skip the --max-idle duration check; kill immediately
                           if score >= threshold. For "I need the GPU NOW."
  --help, -h               Show this help message
  --version                Show version

How It Works:
  Processes must be at least --min-age minutes old to be eligible. Once
  eligible, if a process scores as idle (score >= 8) for --max-idle
  continuous minutes, it is killed.

  Each run, the reaper checks eligible processes:
    - If the process has activity (score < 8), an .alive timestamp is written.
    - If the process looks idle (score >= 8) but was recently active (within
      --max-idle minutes), it is logged as IDLE and skipped.
    - If the process looks idle and has exceeded --max-idle since last activity,
      it is killed (SIGTERM → 10s wait → SIGKILL).

Scoring System:
  No GPU memory at all ................ +3
  GPU memory held, utilization 0% ..... +3
  No CPU time change since last run ... +3
  No network connections (servers) .... +2
  Running > 2 hours ................... +1
  Running > 8 hours ................... +2

  Score >= 8 and idle for >= --max-idle minutes: KILL

Examples:
  tuku                        # Run once in user mode
  tuku --dry-run --verbose    # See what would happen
  tuku --min-age 30 --max-idle 15  # Tighter thresholds
  tuku --force               # Kill idle processes immediately
  tuku list                   # Show all llama processes
  tuku install --interval 3   # Cron every 3 minutes (user)
  tuku install --system       # Cron every 5 minutes (root)
  tuku uninstall              # Remove user cron entry
EOF
    exit 0
}

usage_install() {
    cat <<'EOF'
Usage: tuku install [--system] [--interval MINUTES] [--min-age MINUTES] [--max-idle MINUTES]

Install tuku as a recurring cron job.

Options:
  --system             Install system-wide (requires sudo). Creates
                       /etc/cron.d/tuku running as root.
  --interval MINUTES   How often the reaper runs (default: 5)
  --min-age MINUTES    Minimum process age for reaping eligibility (default: 60).
                       Passed through to the cron entry.
  --max-idle MINUTES   Continuous idle duration before killing (default: 30).
                       Passed through to the cron entry.
  --help, -h           Show this help message

User mode (default):
  Adds an entry to the current user's crontab.

System mode (--system):
  Creates /etc/cron.d/tuku that runs as root, managing
  ALL users' llama.cpp processes.

Examples:
  tuku install                              # User cron, defaults
  tuku install --interval 3 --min-age 30    # Every 3min, 30min age gate
  tuku install --system --max-idle 15        # System-wide, 15min idle
EOF
    exit 0
}

usage_uninstall() {
    cat <<'EOF'
Usage: tuku uninstall [--system]

Remove the tuku cron job.

Options:
  --system       Remove the system-wide cron entry (requires sudo)
  --help, -h     Show this help message
EOF
    exit 0
}

usage_list() {
    cat <<'EOF'
Usage: tuku list

Show all llama.cpp processes on the system with diagnostic info.

Displays: PID, user, GPU memory, port, uptime, idle score, and last active time.
This is read-only — no sudo needed (uses ps and nvidia-smi).
EOF
    exit 0
}

# ---------- Logging ----------

log_file() {
    if [[ "${SYSTEM_MODE}" == true ]]; then
        echo "${SYSTEM_LOG}"
    else
        echo "${USER_LOG}"
    fi
}

log_msg() {
    local level="$1" msg="$2"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local entry="[${ts}] ${level}: ${msg}"

    # Always write to log file
    local lf
    lf="$(log_file)"
    mkdir -p "$(dirname "${lf}")"
    echo "${entry}" >> "${lf}" 2>/dev/null || true

    # Print to stderr if verbose or if it's a kill/idle/error
    if [[ "${VERBOSE}" == true ]] || [[ "${level}" == "KILL" ]] || [[ "${level}" == "IDLE" ]] || [[ "${level}" == "ERROR" ]]; then
        echo "${entry}" >&2
    fi
}

die() {
    printf '[%s] ERROR: %s\n' "$(date '+%H:%M:%S')" "$1" >&2
    exit "${2:-1}"
}

# ---------- Utility ----------

# Ensure state directories exist
ensure_dirs() {
    mkdir -p "${REAPER_STATE_DIR}"
}

# Get CLK_TCK for proc stat calculations (cached)
_CLK_TCK=""
get_clk_tck() {
    if [[ -z "${_CLK_TCK}" ]]; then
        _CLK_TCK="$(getconf CLK_TCK 2>/dev/null || echo 100)"
    fi
    echo "${_CLK_TCK}"
}

# Get system boot time in seconds since epoch
_BOOT_TIME=""
get_boot_time() {
    if [[ -z "${_BOOT_TIME}" ]]; then
        _BOOT_TIME="$(awk '/^btime / {print $2}' /proc/stat 2>/dev/null || echo 0)"
    fi
    echo "${_BOOT_TIME}"
}

# Format seconds into human-readable uptime
format_uptime() {
    local seconds="$1"
    if [[ ${seconds} -lt 60 ]]; then
        printf '%ds' "${seconds}"
    elif [[ ${seconds} -lt 3600 ]]; then
        printf '%dm%ds' "$((seconds / 60))" "$((seconds % 60))"
    else
        printf '%dh%dm' "$((seconds / 3600))" "$(((seconds % 3600) / 60))"
    fi
}

# ---------- Process Discovery ----------

# Exclusion list: common non-llama executables that might appear in args
readonly EXCLUDED_BASENAMES='grep|vim|less|tail|cat|python|bash|sh|editor|nano|emacs'

# Find all llama.cpp processes. Returns lines of "PID USER COMMAND"
# In user mode, filters to current user only.
# Matches LLAMA_PATTERN against the executable basename only, not full args.
find_llama_processes() {
    local ps_output
    # Use ps to get PID, USER, full command — works without sudo
    ps_output="$(ps -eo pid=,user=,args= 2>/dev/null)" || return 0

    local current_user
    current_user="$(whoami)"

    while IFS= read -r line; do
        # Skip empty lines
        [[ -z "${line}" ]] && continue

        # Parse: leading spaces, PID, spaces, USER, spaces, ARGS
        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        # Extract executable basename from the first word of args
        local exe_path exe_basename
        exe_path="$(echo "${args}" | awk '{print $1}')"
        exe_basename="$(basename "${exe_path}" 2>/dev/null)" || exe_basename="${exe_path}"

        # Safety net: skip common non-llama executables
        if echo "${exe_basename}" | grep -qE "^(${EXCLUDED_BASENAMES})$"; then
            continue
        fi

        # Check if the executable basename matches a llama process pattern
        if ! echo "${exe_basename}" | grep -qE "${LLAMA_PATTERN}"; then
            continue
        fi

        # Skip ourselves
        if [[ "${pid}" == "$$" ]]; then
            continue
        fi

        # In user mode, skip processes not owned by current user
        if [[ "${SYSTEM_MODE}" == false ]] && [[ "${user}" != "${current_user}" ]]; then
            continue
        fi

        echo "${pid} ${user} ${args}"
    done <<< "${ps_output}"
}

# ---------- GPU Process Info ----------

# Returns associative-array-like output: "PID GPU_MEM_MIB" per line
get_gpu_processes() {
    nvidia-smi --query-compute-apps=pid,used_gpu_memory \
        --format=csv,noheader,nounits 2>/dev/null | \
        sed 's/,/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//' || true
}

# Get GPU memory for a specific PID (returns MiB or empty)
get_gpu_mem_for_pid() {
    local target_pid="$1"
    local gpu_procs
    gpu_procs="$(get_gpu_processes)"
    [[ -z "${gpu_procs}" ]] && return 0

    while IFS= read -r line; do
        local pid mem
        pid="$(echo "${line}" | awk '{print $1}')"
        mem="$(echo "${line}" | awk '{print $2}')"
        if [[ "${pid}" == "${target_pid}" ]]; then
            echo "${mem}"
            return 0
        fi
    done <<< "${gpu_procs}"
}

# Check if a PID has active GPU SM utilization (returns "active", "idle", or "unknown")
# Uses nvidia-smi pmon for per-process utilization, falls back to device-level query.
get_gpu_utilization_for_pid() {
    local target_pid="$1"

    # Try per-process monitoring first (pmon -c 1 -s u)
    local pmon_output
    pmon_output="$(nvidia-smi pmon -c 1 -s u 2>/dev/null)" || pmon_output=""

    if [[ -n "${pmon_output}" ]]; then
        # pmon output: "# gpu  pid  type  sm  mem  enc  dec  jpg  ofa  command"
        # Skip header lines starting with #, find our PID
        local sm_util
        sm_util="$(echo "${pmon_output}" | awk -v p="${target_pid}" '!/^#/ && $2 == p {print $4; exit}')"

        if [[ -n "${sm_util}" ]]; then
            if [[ "${sm_util}" == "-" ]] || [[ "${sm_util}" -eq 0 ]]; then
                echo "idle"
            else
                echo "active"
            fi
            return 0
        fi
    fi

    # Fallback: check overall GPU utilization as a heuristic
    local gpu_util
    gpu_util="$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -1)" || gpu_util=""

    if [[ -n "${gpu_util}" ]]; then
        # Trim whitespace
        gpu_util="$(echo "${gpu_util}" | tr -d '[:space:]')"
        if [[ "${gpu_util}" -eq 0 ]]; then
            echo "idle"
        else
            echo "unknown"  # GPU is busy but we can't attribute it to this PID
        fi
        return 0
    fi

    echo "unknown"
}

# ---------- Process Info Extraction ----------

# Get CPU time (utime + stime) from /proc/PID/stat
# Fields 14 and 15 (1-indexed) are utime and stime in clock ticks
get_cpu_time() {
    local pid="$1"
    local stat_file="/proc/${pid}/stat"
    [[ -f "${stat_file}" ]] || return 1

    local stat_data
    stat_data="$(cat "${stat_file}" 2>/dev/null)" || return 1

    # /proc/pid/stat has comm in parens which may contain spaces
    # Strip everything up to and including the last ')' to get fields starting at field 3
    local after_comm
    after_comm="${stat_data##*) }"

    # Fields after comm: state(3) ppid(4) ... utime(14-2=12) stime(15-2=13)
    # Since we stripped fields 1-2, utime is field 12, stime is field 13
    local utime stime
    utime="$(echo "${after_comm}" | awk '{print $12}')"
    stime="$(echo "${after_comm}" | awk '{print $13}')"

    if [[ -n "${utime}" ]] && [[ -n "${stime}" ]]; then
        echo "$(( utime + stime ))"
    else
        return 1
    fi
}

# Get process start time in epoch seconds from /proc/PID/stat
# Field 22 (1-indexed) is starttime in clock ticks since boot
get_process_start_epoch() {
    local pid="$1"
    local stat_file="/proc/${pid}/stat"
    [[ -f "${stat_file}" ]] || return 1

    local stat_data
    stat_data="$(cat "${stat_file}" 2>/dev/null)" || return 1

    local after_comm
    after_comm="${stat_data##*) }"

    # starttime is field 22, which is field 20 after stripping fields 1-2
    local starttime
    starttime="$(echo "${after_comm}" | awk '{print $20}')"
    [[ -n "${starttime}" ]] || return 1

    local clk_tck boot_time
    clk_tck="$(get_clk_tck)"
    boot_time="$(get_boot_time)"

    echo "$(( boot_time + starttime / clk_tck ))"
}

# Get the port a process is listening on
get_listen_port() {
    local pid="$1"
    # Use ss to find LISTEN sockets for this PID
    local port
    port="$(ss -tlnp 2>/dev/null | grep "pid=${pid}[,)]" | \
        sed -n 's/.*:\([0-9]\{1,\}\)[[:space:]].*/\1/p' | head -1)" || true
    echo "${port}"
}

# Count ESTABLISHED connections to a given port for a given PID
get_established_connections() {
    local pid="$1" port="$2"
    [[ -z "${port}" ]] && echo "0" && return 0

    local count
    count="$(ss -tnp "( sport = :${port} )" 2>/dev/null | \
        grep -c "ESTAB" 2>/dev/null)" || count=0
    echo "${count}"
}

# Get model name from state file or command line
get_model_name() {
    local pid="$1" cmdline="$2"
    local model=""

    # Parse command line for -m or --model
    model="$(echo "${cmdline}" | sed -n 's/.*\(-m\|--model\)[[:space:]]\{1,\}\(\S\{1,\}\).*/\2/p' | head -1)" || true

    if [[ -n "${model}" ]]; then
        basename "${model}" 2>/dev/null || echo "${model}"
    else
        echo "unknown"
    fi
}

# ---------- CPU Time Two-Sample Comparison ----------

# Save current CPU time sample for a PID
save_cpu_sample() {
    local pid="$1" cpu_time="$2"
    local sample_file="${REAPER_STATE_DIR}/${pid}.cpu"
    echo "$(date +%s) ${cpu_time}" > "${sample_file}"
}

# Load previous CPU time sample for a PID
# Returns "epoch cpu_time" or empty if no sample
load_cpu_sample() {
    local pid="$1"
    local sample_file="${REAPER_STATE_DIR}/${pid}.cpu"
    if [[ -f "${sample_file}" ]]; then
        cat "${sample_file}" 2>/dev/null || true
    fi
}

# ---------- Alive Timestamp Management ----------

# Write/update the .alive timestamp for a PID (epoch seconds)
write_alive_timestamp() {
    local pid="$1"
    local alive_file="${REAPER_STATE_DIR}/${pid}.alive"
    date +%s > "${alive_file}"
}

# Read the .alive timestamp for a PID. Returns epoch seconds or empty.
read_alive_timestamp() {
    local pid="$1"
    local alive_file="${REAPER_STATE_DIR}/${pid}.alive"
    if [[ -f "${alive_file}" ]]; then
        cat "${alive_file}" 2>/dev/null || true
    fi
}

# ---------- Idle Scoring ----------

# Calculate idle score for a process.
# Prints "SCORE reason1; reason2; ..."
# When readonly=false (default), saves CPU sample for next run.
# When readonly=true, skips writing CPU samples and alive timestamps.
calculate_idle_score() {
    local pid="$1" user="$2" cmdline="$3"
    local is_readonly="${4:-false}"
    local score=0
    local reasons=()
    local now
    now="$(date +%s)"

    # --- a. GPU compute activity ---
    local gpu_mem
    gpu_mem="$(get_gpu_mem_for_pid "${pid}")"
    if [[ -z "${gpu_mem}" ]] || [[ "${gpu_mem}" == "0" ]]; then
        score=$((score + 3))
        reasons+=("no GPU memory (+3)")
    else
        # Process holds GPU memory — check if it's actually computing
        local gpu_util_status
        gpu_util_status="$(get_gpu_utilization_for_pid "${pid}")"
        if [[ "${gpu_util_status}" == "active" ]]; then
            reasons+=("GPU mem: ${gpu_mem}MiB, actively computing (+0)")
        elif [[ "${gpu_util_status}" == "idle" ]]; then
            score=$((score + 3))
            reasons+=("GPU mem: ${gpu_mem}MiB, utilization 0% — holding memory idle (+3)")
        else
            # Unknown — can't determine, give benefit of the doubt
            reasons+=("GPU mem: ${gpu_mem}MiB, utilization unknown (+0)")
        fi
    fi

    # --- b. CPU time change (two-sample) ---
    local current_cpu
    current_cpu="$(get_cpu_time "${pid}" 2>/dev/null)" || current_cpu=""

    if [[ -n "${current_cpu}" ]]; then
        local prev_sample
        prev_sample="$(load_cpu_sample "${pid}")"

        if [[ -n "${prev_sample}" ]]; then
            local prev_epoch prev_cpu
            prev_epoch="$(echo "${prev_sample}" | awk '{print $1}')"
            prev_cpu="$(echo "${prev_sample}" | awk '{print $2}')"

            local time_delta=$((now - prev_epoch))
            # Only compare if previous sample is at least 20s old
            if [[ ${time_delta} -ge 20 ]]; then
                local cpu_delta=$((current_cpu - prev_cpu))
                # Consider "idle" if less than 1 tick/second (timer housekeeping noise)
                local tick_rate=0
                if [[ ${time_delta} -gt 0 ]]; then
                    tick_rate=$(( cpu_delta / time_delta ))
                fi
                if [[ ${cpu_delta} -le 0 ]] || [[ ${tick_rate} -lt 1 ]]; then
                    score=$((score + 3))
                    reasons+=("CPU near-idle: +${cpu_delta} ticks in ${time_delta}s (<1 tick/s) (+3)")
                else
                    reasons+=("CPU delta: +${cpu_delta} ticks in ${time_delta}s (+0)")
                fi
            else
                reasons+=("CPU sample too recent (${time_delta}s ago), skipping (+0)")
            fi
        else
            reasons+=("no previous CPU sample, first run (+0)")
        fi

        # Save current sample for next run (skip in readonly mode)
        if [[ "${is_readonly}" != true ]]; then
            save_cpu_sample "${pid}" "${current_cpu}"
        fi
    else
        reasons+=("cannot read CPU time (+0)")
    fi

    # --- c. Network connections (for servers) ---
    local port
    port="$(get_listen_port "${pid}")"
    if [[ -n "${port}" ]]; then
        local conn_count
        conn_count="$(get_established_connections "${pid}" "${port}")"
        if [[ "${conn_count}" -eq 0 ]]; then
            score=$((score + 2))
            reasons+=("no connections on port ${port} (+2)")
        else
            reasons+=("${conn_count} connections on port ${port} (+0)")
        fi
    else
        # Not a server (llama-cli etc) — skip network check
        reasons+=("not listening on any port (+0)")
    fi

    # --- d. Process age ---
    local start_epoch
    start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || start_epoch=0
    if [[ ${start_epoch} -gt 0 ]]; then
        local age_seconds=$((now - start_epoch))
        local age_hours=$((age_seconds / 3600))
        local age_minutes=$((age_seconds / 60))

        if [[ ${age_hours} -ge 8 ]]; then
            score=$((score + 2))
            reasons+=("running > 8h ($(format_uptime "${age_seconds}")) (+2)")
        elif [[ ${age_hours} -ge 2 ]]; then
            score=$((score + 1))
            reasons+=("running > 2h ($(format_uptime "${age_seconds}")) (+1)")
        else
            reasons+=("uptime $(format_uptime "${age_seconds}") (+0)")
        fi

        # Check --min-age: process must be older than min-age minutes to be eligible
        if [[ ${age_minutes} -lt ${MIN_AGE_MINUTES} ]]; then
            # Process is too young — zero out the score
            score=0
            reasons+=("process younger than --min-age (${MIN_AGE_MINUTES}m), NOT eligible")
        fi
    fi

    # Return score and reasons
    local reason_str
    reason_str="$(IFS='; '; echo "${reasons[*]}")"
    echo "${score} ${reason_str}"
}

# ---------- Kill Logic ----------

# Remove all reaper state files for a PID
cleanup_pid_files() {
    local pid="$1"
    rm -f "${REAPER_STATE_DIR}/${pid}.alive" \
          "${REAPER_STATE_DIR}/${pid}.cpu" 2>/dev/null || true
}

# Kill a process: SIGTERM, wait 10s, SIGKILL if needed
kill_process() {
    local pid="$1" user="$2" model="$3" score="$4" reason="$5"

    if [[ "${DRY_RUN}" == true ]]; then
        log_msg "KILL(dry)" "PID=${pid} user=${user} model=${model} score=${score} reason=[${reason}]"
        echo "  [DRY-RUN] Would KILL PID ${pid} (${user}, ${model}, score=${score})"
        return 0
    fi

    log_msg "KILL" "PID=${pid} user=${user} model=${model} score=${score} reason=[${reason}]"
    echo "  KILLING PID ${pid} (${user}, ${model}, score=${score})"

    # SIGTERM first
    kill -TERM "${pid}" 2>/dev/null || true

    # Wait up to 10s
    local waited=0
    while kill -0 "${pid}" 2>/dev/null && [[ ${waited} -lt 10 ]]; do
        sleep 1
        ((waited++))
    done

    # SIGKILL if still alive
    if kill -0 "${pid}" 2>/dev/null; then
        log_msg "KILL" "PID=${pid} still alive after 10s, sending SIGKILL"
        kill -KILL "${pid}" 2>/dev/null || true
    fi

    cleanup_pid_files "${pid}"
}

# ---------- Main Reap Logic ----------

reap() {
    ensure_dirs

    local processes
    processes="$(find_llama_processes)"

    if [[ -z "${processes}" ]]; then
        [[ "${VERBOSE}" == true ]] && echo "No llama.cpp processes found."
        return 0
    fi

    local found_any=false
    local now
    now="$(date +%s)"

    while IFS= read -r proc_line; do
        [[ -z "${proc_line}" ]] && continue
        found_any=true

        local pid user cmdline
        pid="$(echo "${proc_line}" | awk '{print $1}')"
        user="$(echo "${proc_line}" | awk '{print $2}')"
        cmdline="$(echo "${proc_line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        # Verify process still exists
        if ! kill -0 "${pid}" 2>/dev/null; then
            cleanup_pid_files "${pid}"
            continue
        fi

        local model
        model="$(get_model_name "${pid}" "${cmdline}")"

        # Calculate idle score
        local score_result score reason
        score_result="$(calculate_idle_score "${pid}" "${user}" "${cmdline}")"
        score="$(echo "${score_result}" | awk '{print $1}')"
        reason="$(echo "${score_result}" | cut -d' ' -f2-)"

        if [[ "${VERBOSE}" == true ]]; then
            echo "  PID ${pid} (${user}, ${model}): score=${score}"
            echo "    ${reason}"
        fi

        # Decide action based on score
        if [[ ${score} -ge ${SCORE_KILL} ]]; then
            if [[ "${FORCE}" == true ]]; then
                # Force mode: kill immediately, skip max-idle duration check
                kill_process "${pid}" "${user}" "${model}" "${score}" "${reason}"
            else
                # Check .alive timestamp for continuous idle duration
                local alive_ts
                alive_ts="$(read_alive_timestamp "${pid}")"

                if [[ -z "${alive_ts}" ]]; then
                    # First time seeing this process idle — benefit of the doubt
                    # Create .alive with current timestamp (treat as "just became idle now")
                    write_alive_timestamp "${pid}"
                    if [[ "${VERBOSE}" == true ]]; then
                        echo "    → First idle detection, creating .alive timestamp, skipping"
                    fi
                    log_msg "IDLE" "PID=${pid} user=${user} model=${model} score=${score} reason=[first idle detection, benefit of the doubt]"
                else
                    local idle_since=$((now - alive_ts))
                    local max_idle_seconds=$((MAX_IDLE_MINUTES * 60))

                    if [[ ${idle_since} -ge ${max_idle_seconds} ]]; then
                        # Idle for too long — kill
                        kill_process "${pid}" "${user}" "${model}" "${score}" "${reason}"
                    else
                        # Idle but within max-idle window — skip
                        local remaining_minutes=$(( (max_idle_seconds - idle_since) / 60 ))
                        if [[ "${VERBOSE}" == true ]]; then
                            echo "    → Idle but within --max-idle window (last active $((idle_since / 60))m ago, ${remaining_minutes}m remaining)"
                        fi
                        log_msg "IDLE" "PID=${pid} user=${user} model=${model} score=${score} reason=[idle but within max-idle window, last active $((idle_since / 60))m ago]"
                    fi
                fi
            fi
        else
            # Score below threshold — process has activity
            # Write/update .alive timestamp (positive evidence of life)
            if [[ ${score} -gt 0 ]]; then
                # Only write alive if the process is actually eligible (score > 0 means it passed min-age)
                write_alive_timestamp "${pid}"
            fi
            log_msg "SKIP" "PID=${pid} user=${user} model=${model} score=${score} reason=[below threshold]"
        fi
    done <<< "${processes}"

    if [[ "${found_any}" == false ]]; then
        [[ "${VERBOSE}" == true ]] && echo "No llama.cpp processes found."
    fi

    # Clean up stale reaper files for PIDs that no longer exist
    cleanup_stale_reaper_files
}

# Remove reaper state files for PIDs that no longer exist
cleanup_stale_reaper_files() {
    shopt -s nullglob
    local files=("${REAPER_STATE_DIR}"/*.alive "${REAPER_STATE_DIR}"/*.cpu)
    shopt -u nullglob

    for f in "${files[@]}"; do
        local basename_f
        basename_f="$(basename "${f}")"
        local pid="${basename_f%%.*}"
        if [[ -n "${pid}" ]] && ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
        fi
    done
}

# ---------- List Subcommand ----------

cmd_list() {
    # Show ALL llama processes regardless of mode (read-only diagnostic)
    local ps_output
    ps_output="$(ps -eo pid=,user=,args= 2>/dev/null)" || { echo "Failed to run ps"; exit 1; }

    # Get GPU processes once
    local gpu_procs
    gpu_procs="$(get_gpu_processes)"

    # Collect state dirs to check (user dir + system dir for complete picture)
    local system_state_dir="/var/lib/tuku/reaper"
    local state_dirs=("${REAPER_STATE_DIR}")
    if [[ "${REAPER_STATE_DIR}" != "${system_state_dir}" ]] && [[ -d "${system_state_dir}" ]]; then
        state_dirs+=("${system_state_dir}")
    fi

    local entries=()
    local now
    now="$(date +%s)"

    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue

        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        # Extract executable basename from the first word of args
        local exe_path exe_basename
        exe_path="$(echo "${args}" | awk '{print $1}')"
        exe_basename="$(basename "${exe_path}" 2>/dev/null)" || exe_basename="${exe_path}"

        # Safety net: skip common non-llama executables
        if echo "${exe_basename}" | grep -qE "^(${EXCLUDED_BASENAMES})$"; then
            continue
        fi

        # Match LLAMA_PATTERN against basename only
        if ! echo "${exe_basename}" | grep -qE "${LLAMA_PATTERN}"; then
            continue
        fi

        # Skip ourselves
        [[ "${pid}" == "$$" ]] && continue

        # GPU memory
        local gpu_mem="-"
        if [[ -n "${gpu_procs}" ]]; then
            local mem
            mem="$(echo "${gpu_procs}" | awk -v p="${pid}" '$1 == p {print $2}')"
            [[ -n "${mem}" ]] && gpu_mem="${mem}MiB"
        fi

        # Port
        local port
        port="$(get_listen_port "${pid}")"
        [[ -z "${port}" ]] && port="-"

        # Uptime
        local start_epoch uptime_str="-"
        start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || start_epoch=0
        if [[ ${start_epoch} -gt 0 ]]; then
            local age=$((now - start_epoch))
            uptime_str="$(format_uptime "${age}")"
        fi

        # Model
        local model
        model="$(get_model_name "${pid}" "${args}")"

        # Idle score (quick calculation — ensure dirs exist, readonly mode)
        ensure_dirs
        local score_result score
        score_result="$(calculate_idle_score "${pid}" "${user}" "${args}" true)"
        score="$(echo "${score_result}" | awk '{print $1}')"

        # Check for .alive files in ALL state dirs — show last active time
        local last_active_str=""
        for sdir in "${state_dirs[@]}"; do
            if [[ -f "${sdir}/${pid}.alive" ]]; then
                local alive_ts
                alive_ts="$(cat "${sdir}/${pid}.alive" 2>/dev/null)" || continue
                if [[ -n "${alive_ts}" ]]; then
                    local ago=$(( now - alive_ts ))
                    local ago_min=$(( ago / 60 ))
                    last_active_str="last active ${ago_min}m ago"
                fi
                break
            fi
        done

        entries+=("${pid}|${user}|${gpu_mem}|${port}|${uptime_str}|${score}|${model}|${last_active_str}")
    done <<< "${ps_output}"

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No llama.cpp processes found."
        return 0
    fi

    # Table header
    printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
        "PID" "USER" "GPU_MEM" "PORT" "UPTIME" "SCORE" "LAST_ACTIVE" "MODEL"
    printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
        "-------" "------------" "----------" "-------" "----------" "------" "--------------------" "-----"

    for entry in "${entries[@]}"; do
        IFS='|' read -r pid user gpu_mem port uptime score model last_active <<< "${entry}"
        printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
            "${pid}" "${user}" "${gpu_mem}" "${port}" "${uptime}" "${score}" "${last_active}" "${model}"
    done

    echo ""
    echo "${#entries[@]} llama.cpp process(es) found."
}

# ---------- Install / Uninstall Subcommands ----------

cmd_install() {
    local system=false
    local interval=5
    local min_age=""
    local max_idle=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --system)   system=true; shift ;;
            --interval)
                [[ -n "${2:-}" ]] || die "--interval requires a value"
                interval="$2"; shift 2
                ;;
            --min-age)
                [[ -n "${2:-}" ]] || die "--min-age requires a value"
                min_age="$2"; shift 2
                ;;
            --max-idle)
                [[ -n "${2:-}" ]] || die "--max-idle requires a value"
                max_idle="$2"; shift 2
                ;;
            --help|-h)  usage_install ;;
            *)          die "Unknown install option: $1" ;;
        esac
    done

    if [[ "${system}" == true ]]; then
        install_system "${interval}" "${min_age}" "${max_idle}"
    else
        install_user "${interval}" "${min_age}" "${max_idle}"
    fi
}

install_user() {
    local interval="$1"
    local min_age="${2:-}"
    local max_idle="${3:-}"

    # Check if already installed
    local existing
    existing="$(crontab -l 2>/dev/null || true)"
    if echo "${existing}" | grep -q "${CRON_MARKER}"; then
        echo "tuku cron entry already exists. Use 'tuku uninstall' first."
        echo "Current entry:"
        echo "${existing}" | grep "${CRON_MARKER}" -A1
        return 1
    fi

    local extra_flags=""
    if [[ -n "${min_age}" ]]; then
        extra_flags+=" --min-age ${min_age}"
    fi
    if [[ -n "${max_idle}" ]]; then
        extra_flags+=" --max-idle ${max_idle}"
    fi

    local cron_line="*/${interval} * * * * ${SCRIPT_PATH}${extra_flags} ${CRON_MARKER}"

    # Add to crontab
    (echo "${existing}"; echo "${cron_line}") | crontab -

    echo "Installed user cron: runs every ${interval} minutes"
    echo "  ${cron_line}"
    echo ""
    echo "View with: crontab -l"
    echo "Remove with: tuku uninstall"
}

install_system() {
    local interval="$1"
    local min_age="${2:-}"
    local max_idle="${3:-}"

    if [[ "$(id -u)" -ne 0 ]]; then
        local extra_args=()
        [[ -n "${min_age}" ]] && extra_args+=(--min-age "${min_age}")
        [[ -n "${max_idle}" ]] && extra_args+=(--max-idle "${max_idle}")
        echo "System install requires root. Re-running with sudo..."
        exec sudo "${SCRIPT_PATH}" install --system --interval "${interval}" "${extra_args[@]}"
    fi

    local extra_flags=""
    if [[ -n "${min_age}" ]]; then
        extra_flags+=" --min-age ${min_age}"
    fi
    if [[ -n "${max_idle}" ]]; then
        extra_flags+=" --max-idle ${max_idle}"
    fi

    # Create /etc/cron.d entry
    cat > "${SYSTEM_CRON_FILE}" <<EOF
# tuku: watchdog for idle llama.cpp processes
# Installed by: tuku install --system
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin

*/${interval} * * * * root ${SCRIPT_PATH} --system-run${extra_flags} ${CRON_MARKER}
EOF

    chmod 644 "${SYSTEM_CRON_FILE}"

    echo "Installed system cron: ${SYSTEM_CRON_FILE}"
    echo "  Runs every ${interval} minutes as root"
    echo ""
    echo "Remove with: tuku uninstall --system"
}

cmd_uninstall() {
    local system=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --system)   system=true; shift ;;
            --help|-h)  usage_uninstall ;;
            *)          die "Unknown uninstall option: $1" ;;
        esac
    done

    if [[ "${system}" == true ]]; then
        uninstall_system
    else
        uninstall_user
    fi
}

uninstall_user() {
    local existing
    existing="$(crontab -l 2>/dev/null || true)"

    if ! echo "${existing}" | grep -q "${CRON_MARKER}"; then
        echo "No tuku cron entry found in user crontab."
        return 0
    fi

    # Remove lines containing our marker
    echo "${existing}" | grep -v "${CRON_MARKER}" | crontab -

    echo "Removed tuku from user crontab."
}

uninstall_system() {
    if [[ "$(id -u)" -ne 0 ]]; then
        echo "System uninstall requires root. Re-running with sudo..."
        exec sudo "${SCRIPT_PATH}" uninstall --system
    fi

    if [[ -f "${SYSTEM_CRON_FILE}" ]]; then
        rm -f "${SYSTEM_CRON_FILE}"
        echo "Removed ${SYSTEM_CRON_FILE}"
    else
        echo "No system cron file found at ${SYSTEM_CRON_FILE}"
    fi
}

# ---------- Argument Parsing & Main ----------

main() {
    # Handle subcommands first
    if [[ $# -gt 0 ]]; then
        case "$1" in
            list)
                shift
                # Check for --help in remaining args
                for arg in "$@"; do
                    [[ "${arg}" == "--help" || "${arg}" == "-h" ]] && usage_list
                done
                cmd_list "$@"
                return 0
                ;;
            install)
                shift
                cmd_install "$@"
                return 0
                ;;
            uninstall)
                shift
                cmd_uninstall "$@"
                return 0
                ;;
        esac
    fi

    # Parse main options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --min-age)
                [[ -n "${2:-}" ]] || die "--min-age requires a value"
                MIN_AGE_MINUTES="$2"
                shift 2
                ;;
            --max-idle)
                [[ -n "${2:-}" ]] || die "--max-idle requires a value"
                MAX_IDLE_MINUTES="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --force)
                FORCE=true
                shift
                ;;
            --system-run)
                # Internal flag: used by system cron to enable system mode
                SYSTEM_MODE=true
                shift
                ;;
            --help|-h)
                usage
                ;;
            --version)
                echo "tuku ${VERSION}"
                exit 0
                ;;
            *)
                die "Unknown option: $1. Try 'tuku --help'."
                ;;
        esac
    done

    # Override state directories for system mode so cron (running as root)
    # and user diagnostics don't collide on ${HOME}-based paths.
    if [[ "${SYSTEM_MODE}" == true ]]; then
        USER_STATE_DIR="/var/lib/tuku"
        REAPER_STATE_DIR="/var/lib/tuku/reaper"
    fi

    reap
}

main "$@"
