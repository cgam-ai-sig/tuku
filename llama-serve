#!/usr/bin/env bash
set -euo pipefail

# llama-serve — wraps llama-server with automatic inactivity shutdown
# Usage: llama-serve [--timeout MINUTES] [--port PORT] -- [llama-server args...]

readonly STATE_DIR="${HOME}/.local/state/llama-reaper"
readonly SCRIPT_NAME="$(basename "$0")"

# Defaults
TIMEOUT_MINUTES=15
MONITOR_PORT=""
LLAMA_ARGS=()
CHILD_PID=""
SHUTDOWN_REASON=""

usage() {
    cat <<'EOF'
Usage: llama-serve [--timeout MINUTES] [--port PORT] -- [llama-server args...]

Wraps llama-server with automatic inactivity shutdown.

Options:
  --timeout MINUTES   Minutes of inactivity before shutdown (default: 15)
  --port PORT         Port to monitor; auto-detected from llama-server args
                      if --port/-p is passed after the -- separator (default: 8080)
  --help              Show this help message

Everything after "--" is passed directly to llama-server.

Examples:
  llama-serve -- -m model.gguf -c 4096
  llama-serve --timeout 30 -- -m model.gguf --port 9090
  llama-serve --timeout 10 --port 9090 -- -m model.gguf -ngl 99

State files are written to ~/.local/state/llama-reaper/{pid}.json
EOF
    exit 0
}

log() {
    printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$1"
}

die() {
    printf '[%s] ERROR: %s\n' "$(date '+%H:%M:%S')" "$1" >&2
    exit "${2:-1}"
}

# ---------- Argument parsing ----------

parse_wrapper_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout)
                [[ -n "${2:-}" ]] || die "--timeout requires a value"
                TIMEOUT_MINUTES="$2"
                shift 2
                ;;
            --port)
                [[ -n "${2:-}" ]] || die "--port requires a value"
                MONITOR_PORT="$2"
                shift 2
                ;;
            --help|-h)
                usage
                ;;
            --)
                shift
                LLAMA_ARGS=("$@")
                return
                ;;
            *)
                die "Unknown option: $1 (use -- to separate llama-server args)"
                ;;
        esac
    done
}

# Extract --model/-m and --port/-p from the passthrough args
parse_llama_args() {
    local model=""
    local port=""
    local i=0

    while [[ $i -lt ${#LLAMA_ARGS[@]} ]]; do
        case "${LLAMA_ARGS[$i]}" in
            --model|-m)
                if [[ $((i + 1)) -lt ${#LLAMA_ARGS[@]} ]]; then
                    model="${LLAMA_ARGS[$((i + 1))]}"
                fi
                ;;
            --port|-p)
                if [[ $((i + 1)) -lt ${#LLAMA_ARGS[@]} ]]; then
                    port="${LLAMA_ARGS[$((i + 1))]}"
                fi
                ;;
        esac
        ((i++))
    done

    PARSED_MODEL="${model:-unknown}"
    # Wrapper --port overrides; otherwise use what llama-server gets; fallback 8080
    if [[ -z "${MONITOR_PORT}" ]]; then
        MONITOR_PORT="${port:-8080}"
    fi
}

# ---------- Port check ----------

check_port_available() {
    if ss -tln 2>/dev/null | grep -qE ":${MONITOR_PORT}\b"; then
        die "Port ${MONITOR_PORT} is already in use"
    fi
}

# ---------- State file ----------

write_state_file() {
    local pid="$1"
    mkdir -p "${STATE_DIR}"
    local state_file="${STATE_DIR}/${pid}.json"

    cat > "${state_file}" <<ENDJSON
{
  "pid": ${pid},
  "port": ${MONITOR_PORT},
  "user": "$(whoami)",
  "start_time": "$(date -Iseconds)",
  "start_epoch": $(date +%s),
  "model": "${PARSED_MODEL}",
  "timeout_minutes": ${TIMEOUT_MINUTES}
}
ENDJSON
    log "State file written: ${state_file}"
}

remove_state_file() {
    local pid="$1"
    local state_file="${STATE_DIR}/${pid}.json"
    if [[ -f "${state_file}" ]]; then
        rm -f "${state_file}"
        log "State file removed: ${state_file}"
    fi
}

# ---------- Shutdown ----------

shutdown_child() {
    local reason="${1:-unknown}"
    SHUTDOWN_REASON="${reason}"

    if [[ -z "${CHILD_PID}" ]]; then
        return
    fi

    # Guard against repeated calls
    local pid="${CHILD_PID}"
    CHILD_PID=""

    if ! kill -0 "${pid}" 2>/dev/null; then
        remove_state_file "${pid}"
        return
    fi

    log "Sending SIGTERM to llama-server PID ${pid} (${reason})"
    kill -TERM "${pid}" 2>/dev/null || true

    # Wait up to 10s for graceful exit
    local waited=0
    while kill -0 "${pid}" 2>/dev/null && [[ ${waited} -lt 10 ]]; do
        sleep 1
        ((waited++))
    done

    if kill -0 "${pid}" 2>/dev/null; then
        log "llama-server PID ${pid} still alive after 10s, sending SIGKILL"
        kill -KILL "${pid}" 2>/dev/null || true
        wait "${pid}" 2>/dev/null || true
    fi

    remove_state_file "${pid}"
}

# ---------- Signal traps ----------

on_signal() {
    log "Received signal — shutting down"
    shutdown_child "stopped by user signal"
    exit 0
}

on_exit() {
    if [[ -n "${CHILD_PID}" ]]; then
        shutdown_child "${SHUTDOWN_REASON:-script exit}"
    fi
}

trap on_signal INT TERM
trap on_exit EXIT

# ---------- Health / activity check ----------

# Returns 0 if llama-server is actively processing, 1 otherwise
check_health_active() {
    local health
    health=$(curl -s --max-time 2 "http://localhost:${MONITOR_PORT}/health" 2>/dev/null) || return 1

    # Look for slots_processing > 0 in the JSON response
    # Using grep + simple parsing to avoid jq dependency
    local slots_processing
    slots_processing=$(printf '%s' "${health}" | grep -oP '"slots_processing"\s*:\s*\K[0-9]+' 2>/dev/null || echo "0")

    if [[ "${slots_processing}" -gt 0 ]]; then
        return 0
    fi
    return 1
}

# Returns 0 if there are established TCP connections to the port (beyond our own curl)
check_connections_active() {
    local conn_count
    # Count ESTAB connections to our port, exclude connections from our own monitoring
    conn_count=$(ss -tnp "( sport = :${MONITOR_PORT} )" 2>/dev/null \
        | grep -c "ESTAB" 2>/dev/null || echo "0")

    # We expect 0 connections when idle; even 1 ESTAB means a client is connected
    if [[ "${conn_count}" -gt 0 ]]; then
        return 0
    fi
    return 1
}

is_active() {
    check_health_active && return 0
    check_connections_active && return 0
    return 1
}

# ---------- Monitor loop ----------

monitor_inactivity() {
    local inactive_seconds=0
    local timeout_seconds=$((TIMEOUT_MINUTES * 60))
    local poll_interval=10

    while true; do
        sleep "${poll_interval}"

        # Check child is still running
        if ! kill -0 "${CHILD_PID}" 2>/dev/null; then
            log "llama-server PID ${CHILD_PID} exited unexpectedly"
            local dead_pid="${CHILD_PID}"
            CHILD_PID=""
            remove_state_file "${dead_pid}"
            exit 1
        fi

        if is_active; then
            if [[ ${inactive_seconds} -gt 0 ]]; then
                log "Activity detected — resetting inactivity timer"
            fi
            inactive_seconds=0
        else
            inactive_seconds=$((inactive_seconds + poll_interval))
        fi

        if [[ ${inactive_seconds} -ge ${timeout_seconds} ]]; then
            local inactive_min=$((inactive_seconds / 60))
            log "llama-server PID ${CHILD_PID} stopped after ${inactive_min}min inactivity"
            shutdown_child "inactivity timeout (${inactive_min}min)"
            exit 0
        fi
    done
}

# ---------- Main ----------

main() {
    parse_wrapper_args "$@"

    if [[ ${#LLAMA_ARGS[@]} -eq 0 ]]; then
        die "No llama-server arguments provided. Use -- to pass args. Try --help."
    fi

    parse_llama_args
    check_port_available

    log "Launching: llama-server ${LLAMA_ARGS[*]}"
    log "Monitoring port ${MONITOR_PORT}, timeout ${TIMEOUT_MINUTES}min"

    # Launch llama-server in background
    llama-server "${LLAMA_ARGS[@]}" &
    CHILD_PID=$!

    # Wait up to 5 seconds to see if it exits immediately (startup failure)
    local checks=0
    while [[ ${checks} -lt 5 ]]; do
        sleep 1
        ((checks++))
        if ! kill -0 "${CHILD_PID}" 2>/dev/null; then
            local exit_code=0
            wait "${CHILD_PID}" 2>/dev/null || exit_code=$?
            CHILD_PID=""
            die "llama-server exited during startup (exit code ${exit_code})" "${exit_code}"
        fi
    done

    write_state_file "${CHILD_PID}"
    log "Started llama-server PID ${CHILD_PID}, auto-shutdown after ${TIMEOUT_MINUTES}min inactivity"

    monitor_inactivity
}

main "$@"
