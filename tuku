    local no_color=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)     output_mode="json"; shift ;;
            --compact)  output_mode="compact"; shift ;;
            --no-color) no_color=true; shift ;;
            *)          die "Unknown dashboard option: $1. Run 'tuku --help'." ;;
        esac
    done

    if [[ "${no_color}" == true ]] || [[ "${output_mode}" == "json" ]]; then
        BOLD_WHITE=''
        CYAN=''
        GREEN=''
        YELLOW=''
        RED=''
        DIM_GRAY=''
        RESET=''
        USE_COLOR=false
    fi

    # Gather all data upfront
    cache_gpu_data
    parse_gpu_info 2>/dev/null || true
    fetch_ollama
    fetch_reaper                    # Must populate REAPER_STATUS before find_llama_for_dashboard
    find_llama_for_dashboard

    case "${output_mode}" in
        json)    render_json ;;
        compact) render_compact ;;
        default)
            render_gpu
            render_ollama
            render_llama
            render_reaper
            ;;
    esac
}

# ============================================================
# SECTION 5: LIST COMMAND (uses shared + reads reap state, no writes)
# ============================================================

usage_list() {
    cat <<'EOF'
Usage: tuku list

Show all llama.cpp processes on the system with diagnostic info.

Displays: PID, user, GPU memory, port, uptime, idle score, and last active time.
This is read-only — no sudo needed (uses ps and nvidia-smi).
EOF
    exit 0
}

cmd_list() {
    # Pre-filter: single awk pass extracts matching lines only
    local filtered
    filtered="$(ps -eo pid=,user=,args= 2>/dev/null | awk -v pattern="${LLAMA_PATTERN}" -v excluded="${EXCLUDED_BASENAMES}" '
{
    cmd = $3
    n = split(cmd, parts, "/")
    exe = parts[n]
    if (match(exe, excluded)) next
    if (match(exe, pattern)) print $0
}
')" || { echo "Failed to run ps"; exit 1; }

    # Get GPU processes once (reap-style query for scoring)
    local gpu_procs
    gpu_procs="$(get_gpu_processes)"

    # Collect state dirs to check
    local system_state_dir="/var/lib/tuku/reaper"
    local state_dirs=("${REAPER_STATE_DIR}")
    if [[ "${REAPER_STATE_DIR}" != "${system_state_dir}" ]] && [[ -d "${system_state_dir}" ]]; then
        state_dirs+=("${system_state_dir}")
    fi

    local entries=()
    local now
    now="$(date +%s)"

    if [[ -z "${filtered}" ]]; then
        echo "No llama.cpp processes found."
        return 0
    fi

    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue

        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        [[ "${pid}" == "$$" ]] && continue

        # GPU memory
        local gpu_mem="-"
        if [[ -n "${gpu_procs}" ]]; then
            local mem
            mem="$(echo "${gpu_procs}" | awk -v p="${pid}" '$1 == p {print $2}')"
            [[ -n "${mem}" ]] && gpu_mem="${mem}MiB"
        fi

        # Port (try args first, then ss)
        local port
        port="$(get_listen_port "${pid}" "${args}")"
        [[ -z "${port}" ]] && port="-"

        # Uptime
        local start_epoch uptime_str="-"
        start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || start_epoch=0
        if [[ ${start_epoch} -gt 0 ]]; then
            local age=$((now - start_epoch))
            uptime_str="$(format_uptime "${age}")"
        fi

        # Model (try args first, then API)
        local model
        local port_for_model="${port}"
        [[ "${port_for_model}" == "-" ]] && port_for_model=""
        model="$(get_model_name "${pid}" "${args}" "${port_for_model}")"

        # Idle score (readonly mode)
        ensure_dirs
        local score_result score
        score_result="$(calculate_idle_score "${pid}" "${user}" "${args}" true)"
        score="$(echo "${score_result}" | awk '{print $1}')"

        # Check for .alive files in ALL state dirs
        local last_active_str=""
        for sdir in "${state_dirs[@]}"; do
            if [[ -f "${sdir}/${pid}.alive" ]]; then
                local alive_ts
                alive_ts="$(cat "${sdir}/${pid}.alive" 2>/dev/null)" || continue
                if [[ -n "${alive_ts}" ]]; then
                    local ago=$(( now - alive_ts ))
                    local ago_min=$(( ago / 60 ))
                    last_active_str="last active ${ago_min}m ago"
                fi
                break
            fi
        done

        entries+=("${pid}|${user}|${gpu_mem}|${port}|${uptime_str}|${score}|${model}|${last_active_str}")
    done <<< "${filtered}"

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No llama.cpp processes found."
        return 0
    fi

    printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
        "PID" "USER" "GPU_MEM" "PORT" "UPTIME" "SCORE" "LAST_ACTIVE" "MODEL"
    printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
        "-------" "------------" "----------" "-------" "----------" "------" "--------------------" "-----"

    for entry in "${entries[@]}"; do
        IFS='|' read -r pid user gpu_mem port uptime score model last_active <<< "${entry}"
        printf '%-8s %-12s %-10s %-7s %-10s %-6s %-20s %s\n' \
            "${pid}" "${user}" "${gpu_mem}" "${port}" "${uptime}" "${score}" "${last_active}" "${model}"
    done

    echo ""
    echo "${#entries[@]} llama.cpp process(es) found."
}

# ============================================================
# SECTION 6: INSTALL / UNINSTALL
# ============================================================

usage_install() {
    cat <<'EOF'
Usage: tuku install [--system] [--interval MINUTES] [--min-age MINUTES] [--max-idle MINUTES]

Install tuku as a recurring cron job.

Options:
  --system             Install system-wide (requires sudo). Creates
                       /etc/cron.d/tuku running as root.
  --interval MINUTES   How often the reaper runs (default: 1)
  --min-age MINUTES    Minimum process age for reaping eligibility (default: 60).
                       Passed through to the cron entry.
  --max-idle MINUTES   Continuous idle duration before killing (default: 30).
                       Passed through to the cron entry.
  --help, -h           Show this help message

User mode (default):
  Adds an entry to the current user's crontab.

System mode (--system):
  Creates /etc/cron.d/tuku that runs as root, managing
  ALL users' llama.cpp processes.

Examples:
  tuku install                              # User cron, defaults
  tuku install --interval 3 --min-age 30    # Every 3min, 30min age gate
  tuku install --system --max-idle 15        # System-wide, 15min idle
EOF
    exit 0
}

usage_uninstall() {
    cat <<'EOF'
Usage: tuku uninstall [--system]

Remove the tuku cron job.

Options:
  --system       Remove the system-wide cron entry (requires sudo)
  --help, -h     Show this help message
EOF
    exit 0
}

install_user() {
    local interval="$1"
    local min_age="${2:-}"
    local max_idle="${3:-}"

    local existing
    existing="$(crontab -l 2>/dev/null || true)"
    if echo "${existing}" | grep -q "${CRON_MARKER}"; then
        echo "tuku cron entry already exists. Use 'tuku uninstall' first."
        echo "Current entry:"
        echo "${existing}" | grep "${CRON_MARKER}" -A1
        return 1
    fi

    local extra_flags=""
    [[ -n "${min_age}" ]] && extra_flags+=" --min-age ${min_age}"
    [[ -n "${max_idle}" ]] && extra_flags+=" --max-idle ${max_idle}"

    local cron_line="*/${interval} * * * * ${SCRIPT_PATH} reap${extra_flags} ${CRON_MARKER}"

    (echo "${existing}"; echo "${cron_line}") | crontab -

    echo "Installed user cron: runs every ${interval} minutes"
    echo "  ${cron_line}"
    echo ""
    echo "View with: crontab -l"
    echo "Remove with: tuku uninstall"
}

install_system() {
    local interval="$1"
    local min_age="${2:-}"
    local max_idle="${3:-}"

    if [[ "$(id -u)" -ne 0 ]]; then
        local extra_args=()
        [[ -n "${min_age}" ]] && extra_args+=(--min-age "${min_age}")
        [[ -n "${max_idle}" ]] && extra_args+=(--max-idle "${max_idle}")
        echo "System install requires root. Re-running with sudo..."
        exec sudo "${SCRIPT_PATH}" install --system --interval "${interval}" "${extra_args[@]}"
    fi

    local extra_flags=""
    [[ -n "${min_age}" ]] && extra_flags+=" --min-age ${min_age}"
    [[ -n "${max_idle}" ]] && extra_flags+=" --max-idle ${max_idle}"

    cat > "${SYSTEM_CRON_FILE}" <<EOF
# tuku: watchdog for idle llama.cpp processes
# Installed by: tuku install --system
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin

*/${interval} * * * * root ${SCRIPT_PATH} reap --system${extra_flags} ${CRON_MARKER}
EOF

    chmod 644 "${SYSTEM_CRON_FILE}"

    echo "Installed system cron: ${SYSTEM_CRON_FILE}"
    echo "  Runs every ${interval} minutes as root"
    echo ""
    echo "Remove with: tuku uninstall --system"
}

uninstall_user() {
    local existing
    existing="$(crontab -l 2>/dev/null || true)"

    if ! echo "${existing}" | grep -q "${CRON_MARKER}"; then
        echo "No tuku cron entry found in user crontab."
        return 0
    fi

    echo "${existing}" | grep -v "${CRON_MARKER}" | crontab -
    echo "Removed tuku from user crontab."
}

uninstall_system() {
    if [[ "$(id -u)" -ne 0 ]]; then
        echo "System uninstall requires root. Re-running with sudo..."
        exec sudo "${SCRIPT_PATH}" uninstall --system
    fi

    if [[ -f "${SYSTEM_CRON_FILE}" ]]; then
        rm -f "${SYSTEM_CRON_FILE}"
        echo "Removed ${SYSTEM_CRON_FILE}"
    else
        echo "No system cron file found at ${SYSTEM_CRON_FILE}"
    fi
}

cmd_install() {
    local system=false
    local interval=1
    local min_age=""
    local max_idle=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --system)   system=true; shift ;;
            --interval)
                [[ -n "${2:-}" ]] || die "--interval requires a value"
                interval="$2"; shift 2 ;;
            --min-age)
                [[ -n "${2:-}" ]] || die "--min-age requires a value"
                min_age="$2"; shift 2 ;;
            --max-idle)
                [[ -n "${2:-}" ]] || die "--max-idle requires a value"
                max_idle="$2"; shift 2 ;;
            --help|-h)  usage_install ;;
            *)          die "Unknown install option: $1" ;;
        esac
    done

    if [[ "${system}" == true ]]; then
        install_system "${interval}" "${min_age}" "${max_idle}"
    else
        install_user "${interval}" "${min_age}" "${max_idle}"
    fi
}

cmd_uninstall() {
    local system=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --system)   system=true; shift ;;
            --help|-h)  usage_uninstall ;;
            *)          die "Unknown uninstall option: $1" ;;
        esac
    done

    if [[ "${system}" == true ]]; then
        uninstall_system
    else
        uninstall_user
    fi
}

# ============================================================
# SECTION 7: KILL COMMAND
# ============================================================

usage_kill() {
    cat <<'EOF'
Usage: tuku kill <PID> [PID...]

Manually kill one or more llama.cpp processes.

Validates that each PID is a llama.cpp process before killing.
Uses SIGTERM first, waits 10 seconds, then SIGKILL if needed.

Examples:
  tuku kill 12345              # Kill a single process
  tuku kill 12345 67890        # Kill multiple processes
EOF
    exit 0
}

cmd_kill() {
    if [[ $# -eq 0 ]]; then
        die "tuku kill requires at least one PID. Run 'tuku kill --help'."
    fi

    # Check for --help
    for arg in "$@"; do
        [[ "${arg}" == "--help" || "${arg}" == "-h" ]] && usage_kill
    done

    ensure_dirs

    local any_killed=false

    for target_pid in "$@"; do
        # Validate PID is numeric
        if ! [[ "${target_pid}" =~ ^[0-9]+$ ]]; then
            echo "  ERROR: '${target_pid}' is not a valid PID (skipping)"
            continue
        fi

        # Check process exists
        if ! kill -0 "${target_pid}" 2>/dev/null; then
            echo "  ERROR: PID ${target_pid} does not exist (skipping)"
            continue
        fi

        # Get process command line
        local proc_args
        proc_args="$(ps -o args= -p "${target_pid}" 2>/dev/null)" || proc_args=""
        if [[ -z "${proc_args}" ]]; then
            echo "  ERROR: Cannot read command line for PID ${target_pid} (skipping)"
            continue
        fi

        # Verify it matches LLAMA_PATTERN (basename check)
        local exe_path exe_basename
        exe_path="$(echo "${proc_args}" | awk '{print $1}')"
        exe_basename="$(basename "${exe_path}" 2>/dev/null)" || exe_basename="${exe_path}"

        if ! echo "${exe_basename}" | grep -qE "${LLAMA_PATTERN}"; then
            echo "  ERROR: PID ${target_pid} (${exe_basename}) is not a llama.cpp process (skipping)"
            continue
        fi

        # Get process info for display
        local proc_user
        proc_user="$(ps -o user= -p "${target_pid}" 2>/dev/null)" || proc_user="unknown"

        local port
        port="$(get_listen_port "${target_pid}" "${proc_args}")"
        local model
        model="$(get_model_name "${target_pid}" "${proc_args}" "${port}")"

        echo "  Killing PID ${target_pid} (user=${proc_user}, model=${model}, port=${port:-none})"

        # SIGTERM first
        kill -TERM "${target_pid}" 2>/dev/null || true

        local waited=0
        while kill -0 "${target_pid}" 2>/dev/null && [[ ${waited} -lt 10 ]]; do
            sleep 1
            ((waited++))
        done

        if kill -0 "${target_pid}" 2>/dev/null; then
            echo "    Still alive after 10s, sending SIGKILL..."
            kill -KILL "${target_pid}" 2>/dev/null || true
        fi

        # Clean up state files
        cleanup_pid_files "${target_pid}"

        if ! kill -0 "${target_pid}" 2>/dev/null; then
            echo "    Killed successfully."
            any_killed=true
        else
            echo "    WARNING: Process may still be running."
        fi
    done

    if [[ "${any_killed}" == false ]]; then
        echo "No processes were killed."
    fi
}

# ============================================================
# SECTION 8: HELP & MAIN DISPATCHER
# ============================================================

usage() {
    cat <<'EOF'
Usage: tuku [COMMAND] [OPTIONS]

GPU process management for shared servers running llama.cpp.

Commands:
  (default)    Show GPU status dashboard
  reap         Run idle process detection and cleanup
  list         Show all llama.cpp processes with diagnostic info
  install      Set up automatic reaping via cron
  uninstall    Remove the cron job
  kill <PID>   Manually kill a llama.cpp process

Dashboard Options:
  --json       Output as JSON
  --compact    Single-line summary
  --no-color   Strip ANSI colors

Run 'tuku <command> --help' for command-specific options.
EOF
    exit 0
}

main() {
    case "${1:-}" in
        reap)      shift; cmd_reap "$@" ;;
        list)
            shift
            for arg in "$@"; do
                [[ "${arg}" == "--help" || "${arg}" == "-h" ]] && usage_list
            done
            cmd_list "$@"
            ;;
        install)   shift; cmd_install "$@" ;;
        uninstall) shift; cmd_uninstall "$@" ;;
        kill)      shift; cmd_kill "$@" ;;
        --help|-h) usage ;;
        --version) echo "tuku ${VERSION}"; exit 0 ;;
        --json|--compact|--no-color)
            cmd_dashboard "$@" ;;
        "")
            cmd_dashboard ;;
        *)
            die "Unknown command: $1. Run 'tuku --help' for usage." ;;
    esac
}

main "$@"
