#!/usr/bin/env bash
set -euo pipefail

# llama-status — GPU status dashboard
# Neofetch-style display of GPU, Ollama, llama.cpp, and reaper status.

readonly VERSION="2.0.0"
readonly SCRIPT_NAME="$(basename "$0")"

# ---------- Color Scheme ----------

BOLD_WHITE='\033[1;37m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
RESET='\033[0m'

NO_COLOR=false

# ---------- Usage ----------

usage() {
    cat <<'EOF'
Usage: llama-status [--json] [--compact] [--no-color] [--help]

GPU status dashboard with Ollama, llama.cpp, and reaper info.

Options:
  --json       Output all section data as JSON
  --compact    Single-line summary
  --no-color   Strip ANSI color codes (for piping)
  --help       Show this help message
EOF
    exit 0
}

# ---------- Output Mode ----------

OUTPUT_MODE="default"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json)     OUTPUT_MODE="json"; shift ;;
        --compact)  OUTPUT_MODE="compact"; shift ;;
        --no-color) NO_COLOR=true; shift ;;
        --help|-h)  usage ;;
        *)          printf 'Unknown option: %s\n' "$1" >&2; exit 1 ;;
    esac
done

if [[ "${NO_COLOR}" == true ]]; then
    BOLD_WHITE=''
    CYAN=''
    GREEN=''
    YELLOW=''
    RED=''
    RESET=''
fi

# ---------- Helpers ----------

# Print colored text
c() {
    local color="$1" text="$2"
    printf '%b%s%b' "${color}" "${text}" "${RESET}"
}

# Section header: ━━━ Title ━━━━━━━━━━━━━━━━━━━━━━━
section_header() {
    local title="$1"
    local total_width=49
    local prefix="━━━ "
    local suffix_char="━"
    local prefix_len=${#prefix}
    local title_len=${#title}
    local space_after=" "
    local used=$(( prefix_len + title_len + 1 ))
    local remaining=$(( total_width - used ))
    [[ ${remaining} -lt 1 ]] && remaining=1
    local suffix=""
    for ((i = 0; i < remaining; i++)); do
        suffix+="${suffix_char}"
    done
    printf '%b%s%b%s%s%b\n' "${BOLD_WHITE}" "${prefix}" "${CYAN}" "${title}" "${space_after}" "${RESET}"
    # Actually print the full line with fill
    :
}

# Better section header that matches spec exactly
print_header() {
    local title="$1"
    local total_width=49
    local pre="━━━ "
    local post_char="━"
    local pre_len=4  # "━━━ " is 4 chars visually
    local title_len=${#title}
    local space=1
    local fill_len=$(( total_width - pre_len - title_len - space ))
    [[ ${fill_len} -lt 1 ]] && fill_len=1
    local fill=""
    for ((i = 0; i < fill_len; i++)); do
        fill+="━"
    done
    printf '%b━━━ %s %s%b\n' "${BOLD_WHITE}" "${title}" "${fill}" "${RESET}"
}

# Progress bar: current, max, width → ━━━━━━━─── XX%
progress_bar() {
    local current="$1" max="$2" width="${3:-15}"
    local pct=0
    if [[ ${max} -gt 0 ]]; then
        pct=$(( current * 100 / max ))
    fi
    local filled=$(( current * width / (max > 0 ? max : 1) ))
    [[ ${filled} -gt ${width} ]] && filled=${width}
    local empty=$(( width - filled ))
    local bar=""
    for ((i = 0; i < filled; i++)); do
        bar+="━"
    done
    for ((i = 0; i < empty; i++)); do
        bar+="─"
    done

    # Color the bar based on percentage
    local bar_color="${GREEN}"
    if [[ ${pct} -ge 90 ]]; then
        bar_color="${RED}"
    elif [[ ${pct} -ge 70 ]]; then
        bar_color="${YELLOW}"
    fi

    printf '%b%s%b %s%%' "${bar_color}" "${bar}" "${RESET}" "${pct}"
}

# Format uptime from seconds
format_uptime() {
    local seconds="$1"
    if [[ ${seconds} -lt 3600 ]]; then
        printf '%dm' "$((seconds / 60))"
    elif [[ ${seconds} -lt 86400 ]]; then
        printf '%dh %dm' "$((seconds / 3600))" "$(((seconds % 3600) / 60))"
    else
        printf '%dd %dh' "$((seconds / 86400))" "$(((seconds % 86400) / 3600))"
    fi
}

# Extract a string value from minimal JSON (no jq)
json_str() {
    local key="$1" data="$2"
    printf '%s' "${data}" | grep -oP "\"${key}\"\s*:\s*\"\K[^\"]*" 2>/dev/null || echo ""
}

# Extract a numeric value from minimal JSON
json_num() {
    local key="$1" data="$2"
    printf '%s' "${data}" | grep -oP "\"${key}\"\s*:\s*\K[0-9]+" 2>/dev/null || echo "0"
}

# Label + value helper for consistent formatting
label_val() {
    local label="$1" value="$2"
    printf '  %b%-8s%b %b%s%b\n' "${BOLD_WHITE}" "${label}" "${RESET}" "${CYAN}" "${value}" "${RESET}"
}

# ---------- Cached Data Sources ----------

# Call nvidia-smi ONCE for GPU info
GPU_INFO=""
GPU_PROCS=""
GPU_AVAILABLE=false

cache_gpu_data() {
    if command -v nvidia-smi &>/dev/null; then
        GPU_INFO="$(nvidia-smi --query-gpu=name,memory.used,memory.total,temperature.gpu,power.draw,power.limit,utilization.gpu --format=csv,noheader,nounits 2>/dev/null)" || GPU_INFO=""
        GPU_PROCS="$(nvidia-smi --query-compute-apps=pid,used_gpu_memory --format=csv,noheader,nounits 2>/dev/null)" || GPU_PROCS=""
        if [[ -n "${GPU_INFO}" ]]; then
            GPU_AVAILABLE=true
        fi
    fi
}

# Get GPU VRAM for a specific PID from cached data
get_vram_for_pid() {
    local target_pid="$1"
    [[ -z "${GPU_PROCS}" ]] && echo "" && return 0
    local mem
    mem="$(echo "${GPU_PROCS}" | sed 's/,/ /g; s/^[[:space:]]*//' | awk -v p="${target_pid}" '$1 == p {print $2; exit}')" || mem=""
    echo "${mem}"
}

# ---------- Process Uptime via /proc ----------

_CLK_TCK=""
get_clk_tck() {
    if [[ -z "${_CLK_TCK}" ]]; then
        _CLK_TCK="$(getconf CLK_TCK 2>/dev/null || echo 100)"
    fi
    echo "${_CLK_TCK}"
}

_BOOT_TIME=""
get_boot_time() {
    if [[ -z "${_BOOT_TIME}" ]]; then
        _BOOT_TIME="$(awk '/^btime / {print $2}' /proc/stat 2>/dev/null || echo 0)"
    fi
    echo "${_BOOT_TIME}"
}

get_process_start_epoch() {
    local pid="$1"
    local stat_file="/proc/${pid}/stat"
    [[ -f "${stat_file}" ]] || return 1
    local stat_data
    stat_data="$(cat "${stat_file}" 2>/dev/null)" || return 1
    local after_comm="${stat_data##*) }"
    local starttime
    starttime="$(echo "${after_comm}" | awk '{print $20}')"
    [[ -n "${starttime}" ]] || return 1
    local clk_tck boot_time
    clk_tck="$(get_clk_tck)"
    boot_time="$(get_boot_time)"
    echo "$(( boot_time + starttime / clk_tck ))"
}

get_process_uptime_seconds() {
    local pid="$1"
    local start_epoch
    start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || echo "0"
    if [[ -n "${start_epoch}" ]] && [[ "${start_epoch}" -gt 0 ]]; then
        echo "$(( $(date +%s) - start_epoch ))"
    else
        echo "0"
    fi
}

# ---------- Section 1: GPU Overview ----------

# Parsed GPU fields (populated by cache_gpu_data)
GPU_NAME="" GPU_MEM_USED=0 GPU_MEM_TOTAL=0 GPU_TEMP=0
GPU_POWER_DRAW=0 GPU_POWER_LIMIT=0 GPU_UTIL=0

parse_gpu_info() {
    [[ "${GPU_AVAILABLE}" != true ]] && return 1
    # CSV: name, memory.used, memory.total, temperature.gpu, power.draw, power.limit, utilization.gpu
    # Values may have spaces after commas and decimals in power
    IFS=',' read -r _name _mem_used _mem_total _temp _pow_draw _pow_limit _util <<< "${GPU_INFO}"
    GPU_NAME="$(echo "${_name}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    GPU_MEM_USED="$(echo "${_mem_used}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_MEM_TOTAL="$(echo "${_mem_total}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_TEMP="$(echo "${_temp}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_POWER_DRAW="$(echo "${_pow_draw}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_POWER_LIMIT="$(echo "${_pow_limit}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    GPU_UTIL="$(echo "${_util}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | cut -d. -f1)"
    return 0
}

render_gpu() {
    print_header "GPU"
    if [[ "${GPU_AVAILABLE}" != true ]]; then
        printf '  %b%s%b\n' "${RED}" "nvidia-smi not available" "${RESET}"
        return
    fi
    parse_gpu_info || return

    label_val "GPU" "${GPU_NAME}"

    # VRAM bar
    local vram_bar
    vram_bar="$(progress_bar "${GPU_MEM_USED}" "${GPU_MEM_TOTAL}" 15)"
    printf '  %b%-8s%b %b%s / %s MiB%b  %s\n' \
        "${BOLD_WHITE}" "VRAM" "${RESET}" \
        "${CYAN}" "${GPU_MEM_USED}" "${GPU_MEM_TOTAL}" "${RESET}" \
        "${vram_bar}"

    # Temp color
    local temp_color="${GREEN}"
    if [[ ${GPU_TEMP} -ge 80 ]]; then
        temp_color="${RED}"
    elif [[ ${GPU_TEMP} -ge 65 ]]; then
        temp_color="${YELLOW}"
    fi

    # Util color
    local util_color="${CYAN}"

    printf '  %b%-8s%b %b%s°C%b    %b%-8s%b %b%sW / %sW%b    %b%-6s%b %b%s%%%b\n' \
        "${BOLD_WHITE}" "Temp" "${RESET}" "${temp_color}" "${GPU_TEMP}" "${RESET}" \
        "${BOLD_WHITE}" "Power" "${RESET}" "${CYAN}" "${GPU_POWER_DRAW}" "${GPU_POWER_LIMIT}" "${RESET}" \
        "${BOLD_WHITE}" "Util" "${RESET}" "${util_color}" "${GPU_UTIL}" "${RESET}"
}

# ---------- Section 2: Ollama ----------

OLLAMA_STATUS="" OLLAMA_MODELS_JSON="" OLLAMA_MODEL_COUNT=0
OLLAMA_MODELS_DISPLAY=()

fetch_ollama() {
    local response
    response="$(curl -s --max-time 2 http://localhost:11434/api/ps 2>/dev/null)" || response=""
    if [[ -z "${response}" ]]; then
        OLLAMA_STATUS="down"
        return
    fi
    OLLAMA_STATUS="running"
    OLLAMA_MODELS_JSON="${response}"

    # Count models: count occurrences of "name" keys in the models array
    OLLAMA_MODEL_COUNT="$(printf '%s' "${response}" | grep -oP '"name"\s*:\s*"[^"]*"' | wc -l)" || OLLAMA_MODEL_COUNT=0

    # Extract model details: name, size, expires_at
    local names sizes expires
    mapfile -t names < <(printf '%s' "${response}" | grep -oP '"name"\s*:\s*"\K[^"]*' 2>/dev/null || true)
    mapfile -t sizes < <(printf '%s' "${response}" | grep -oP '"size"\s*:\s*\K[0-9]+' 2>/dev/null || true)
    mapfile -t expires < <(printf '%s' "${response}" | grep -oP '"expires_at"\s*:\s*"\K[^"]*' 2>/dev/null || true)

    OLLAMA_MODELS_DISPLAY=()
    local now_epoch
    now_epoch="$(date +%s)"
    for i in "${!names[@]}"; do
        local name="${names[$i]}"
        local size="${sizes[$i]:-0}"
        local expire="${expires[$i]:-}"

        # Convert size from bytes to GB
        local size_gb=0
        if [[ ${size} -gt 0 ]]; then
            size_gb=$(( size / 1073741824 ))
            # If less than 1 GB, show as 1
            [[ ${size_gb} -eq 0 ]] && size_gb=1
        fi

        # Calculate time until expiry
        local until_str=""
        if [[ -n "${expire}" ]]; then
            # Parse ISO 8601 date — try date -d
            local expire_epoch
            expire_epoch="$(date -d "${expire}" +%s 2>/dev/null)" || expire_epoch=0
            if [[ ${expire_epoch} -gt 0 ]]; then
                local remaining=$(( expire_epoch - now_epoch ))
                if [[ ${remaining} -gt 0 ]]; then
                    local remain_min=$(( remaining / 60 ))
                    until_str="until ${remain_min}m"
                else
                    until_str="expiring"
                fi
            fi
        fi

        local display="${name} (${size_gb} GB"
        if [[ -n "${until_str}" ]]; then
            display+=", ${until_str}"
        fi
        display+=")"
        OLLAMA_MODELS_DISPLAY+=("${display}")
    done
}

render_ollama() {
    print_header "Ollama"
    if [[ "${OLLAMA_STATUS}" == "down" ]]; then
        printf '  %b%-8s%b %b● down%b\n' \
            "${BOLD_WHITE}" "Status" "${RESET}" "${RED}" "${RESET}"
        return
    fi

    local status_color="${GREEN}"
    printf '  %b%-8s%b %b● running%b (%s models loaded)\n' \
        "${BOLD_WHITE}" "Status" "${RESET}" "${status_color}" "${RESET}" "${OLLAMA_MODEL_COUNT}"

    if [[ ${OLLAMA_MODEL_COUNT} -gt 0 ]] && [[ ${#OLLAMA_MODELS_DISPLAY[@]} -gt 0 ]]; then
        # First model with label
        printf '  %b%-8s%b %b%s%b\n' \
            "${BOLD_WHITE}" "Active" "${RESET}" "${CYAN}" "${OLLAMA_MODELS_DISPLAY[0]}" "${RESET}"
        # Subsequent models indented
        for ((i = 1; i < ${#OLLAMA_MODELS_DISPLAY[@]}; i++)); do
            printf '           %b%s%b\n' "${CYAN}" "${OLLAMA_MODELS_DISPLAY[$i]}" "${RESET}"
        done
    fi
}

# ---------- Section 3: llama.cpp Processes ----------

# Llama process pattern (same as reaper)
readonly LLAMA_PATTERN='llama-server|llama-cli|llama-cpp|llama\.cpp'

# Arrays for llama.cpp process data
LLAMA_PIDS=()
LLAMA_USERS=()
LLAMA_VRAMS=()
LLAMA_MODELS=()
LLAMA_PORTS=()
LLAMA_UPTIMES=()

find_llama_processes() {
    local ps_output
    ps_output="$(ps -eo pid=,user=,args= 2>/dev/null)" || return 0

    local now_epoch
    now_epoch="$(date +%s)"

    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue

        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        if ! echo "${args}" | grep -qE "${LLAMA_PATTERN}"; then
            continue
        fi

        # Skip ourselves
        [[ "${pid}" == "$$" ]] && continue

        LLAMA_PIDS+=("${pid}")
        LLAMA_USERS+=("${user}")

        # VRAM from cached nvidia-smi data
        local vram
        vram="$(get_vram_for_pid "${pid}")"
        if [[ -n "${vram}" ]] && [[ "${vram}" != "0" ]]; then
            LLAMA_VRAMS+=("${vram} MiB")
        else
            LLAMA_VRAMS+=("-")
        fi

        # Model: parse -m or --model from args
        local model=""
        model="$(echo "${args}" | grep -oP '(-m|--model)\s+\K\S+' | head -1)" || model=""

        # Parse port from args: --port
        local port=""
        port="$(echo "${args}" | grep -oP '--port\s+\K[0-9]+' | head -1)" || port=""

        # If no port from args, try ss
        if [[ -z "${port}" ]]; then
            port="$(ss -tlnp 2>/dev/null | grep "pid=${pid}[,)]" | grep -oP ':\K[0-9]+(?=\s)' | head -1)" || port=""
        fi

        # If no model from args, try the API
        if [[ -z "${model}" ]] && [[ -n "${port}" ]]; then
            local api_response
            api_response="$(curl -s --max-time 1 "http://localhost:${port}/v1/models" 2>/dev/null)" || api_response=""
            if [[ -n "${api_response}" ]]; then
                model="$(printf '%s' "${api_response}" | grep -oP '"id"\s*:\s*"\K[^"]*' | head -1)" || model=""
            fi
        fi

        # Basename for cleaner display
        if [[ -n "${model}" ]]; then
            model="$(basename "${model}" 2>/dev/null || echo "${model}")"
        else
            model="unknown"
        fi
        LLAMA_MODELS+=("${model}")

        LLAMA_PORTS+=("${port:-"-"}")

        # Uptime
        local uptime_sec
        uptime_sec="$(get_process_uptime_seconds "${pid}")"
        if [[ ${uptime_sec} -gt 0 ]]; then
            LLAMA_UPTIMES+=("$(format_uptime "${uptime_sec}")")
        else
            LLAMA_UPTIMES+=("-")
        fi

    done <<< "${ps_output}"
}

render_llama() {
    print_header "llama.cpp"
    if [[ ${#LLAMA_PIDS[@]} -eq 0 ]]; then
        printf '  No active processes\n'
        return
    fi

    # Table header
    printf '  %b%-8s %-8s %-11s %-30s %-7s %s%b\n' \
        "${BOLD_WHITE}" "PID" "USER" "VRAM" "MODEL" "PORT" "UPTIME" "${RESET}"

    for i in "${!LLAMA_PIDS[@]}"; do
        printf '  %b%-8s%b %b%-8s%b %b%-11s%b %b%-30s%b %b%-7s%b %b%s%b\n' \
            "${CYAN}" "${LLAMA_PIDS[$i]}" "${RESET}" \
            "${CYAN}" "${LLAMA_USERS[$i]}" "${RESET}" \
            "${CYAN}" "${LLAMA_VRAMS[$i]}" "${RESET}" \
            "${CYAN}" "${LLAMA_MODELS[$i]}" "${RESET}" \
            "${CYAN}" "${LLAMA_PORTS[$i]}" "${RESET}" \
            "${CYAN}" "${LLAMA_UPTIMES[$i]}" "${RESET}"
    done
}

# ---------- Section 4: Reaper ----------

REAPER_STATUS="" REAPER_INTERVAL="" REAPER_MAX_IDLE=""

fetch_reaper() {
    local cron_file="/etc/cron.d/llama-reaper"
    if [[ -f "${cron_file}" ]]; then
        REAPER_STATUS="active"
        # Parse interval from */N pattern
        REAPER_INTERVAL="$(grep -oP '^\*/\K[0-9]+' "${cron_file}" 2>/dev/null | head -1)" || REAPER_INTERVAL=""
        # Parse --max-idle value
        REAPER_MAX_IDLE="$(grep -oP '\-\-max-idle\s+\K[0-9]+' "${cron_file}" 2>/dev/null | head -1)" || REAPER_MAX_IDLE=""
        return
    fi

    # Check user crontab
    local user_cron
    user_cron="$(crontab -l 2>/dev/null)" || user_cron=""
    if echo "${user_cron}" | grep -q "llama-reaper"; then
        REAPER_STATUS="active"
        REAPER_INTERVAL="$(echo "${user_cron}" | grep "llama-reaper" | grep -oP '^\*/\K[0-9]+' | head -1)" || REAPER_INTERVAL=""
        REAPER_MAX_IDLE="$(echo "${user_cron}" | grep "llama-reaper" | grep -oP '\-\-max-idle\s+\K[0-9]+' | head -1)" || REAPER_MAX_IDLE=""
        return
    fi

    REAPER_STATUS="not installed"
}

render_reaper() {
    print_header "Reaper"
    if [[ "${REAPER_STATUS}" == "active" ]]; then
        local detail=""
        if [[ -n "${REAPER_INTERVAL}" ]] || [[ -n "${REAPER_MAX_IDLE}" ]]; then
            detail=" ("
            [[ -n "${REAPER_INTERVAL}" ]] && detail+="every ${REAPER_INTERVAL}m"
            if [[ -n "${REAPER_MAX_IDLE}" ]]; then
                [[ -n "${REAPER_INTERVAL}" ]] && detail+=", "
                detail+="max-idle ${REAPER_MAX_IDLE}m"
            fi
            detail+=")"
        fi
        printf '  %b%-8s%b %b● active%s%b\n' \
            "${BOLD_WHITE}" "Status" "${RESET}" "${GREEN}" "${detail}" "${RESET}"
    else
        printf '  %b%-8s%b %b● not installed%b\n' \
            "${BOLD_WHITE}" "Status" "${RESET}" "${YELLOW}" "${RESET}"
    fi
}

# ---------- JSON Output ----------

render_json() {
    printf '{\n'

    # GPU section
    printf '  "gpu": {\n'
    if [[ "${GPU_AVAILABLE}" == true ]]; then
        parse_gpu_info
        printf '    "available": true,\n'
        printf '    "name": "%s",\n' "${GPU_NAME}"
        printf '    "vram_used_mib": %s,\n' "${GPU_MEM_USED}"
        printf '    "vram_total_mib": %s,\n' "${GPU_MEM_TOTAL}"
        printf '    "temperature_c": %s,\n' "${GPU_TEMP}"
        printf '    "power_draw_w": %s,\n' "${GPU_POWER_DRAW}"
        printf '    "power_limit_w": %s,\n' "${GPU_POWER_LIMIT}"
        printf '    "utilization_pct": %s\n' "${GPU_UTIL}"
    else
        printf '    "available": false\n'
    fi
    printf '  },\n'

    # Ollama section
    printf '  "ollama": {\n'
    printf '    "status": "%s",\n' "${OLLAMA_STATUS}"
    printf '    "models_loaded": %s,\n' "${OLLAMA_MODEL_COUNT}"
    printf '    "models": [\n'
    if [[ ${#OLLAMA_MODELS_DISPLAY[@]} -gt 0 ]]; then
        for i in "${!OLLAMA_MODELS_DISPLAY[@]}"; do
            local comma=","
            [[ $i -eq $(( ${#OLLAMA_MODELS_DISPLAY[@]} - 1 )) ]] && comma=""
            printf '      "%s"%s\n' "${OLLAMA_MODELS_DISPLAY[$i]}" "${comma}"
        done
    fi
    printf '    ]\n'
    printf '  },\n'

    # llama.cpp section
    printf '  "llama_cpp": {\n'
    printf '    "process_count": %s,\n' "${#LLAMA_PIDS[@]}"
    printf '    "processes": [\n'
    if [[ ${#LLAMA_PIDS[@]} -gt 0 ]]; then
        for i in "${!LLAMA_PIDS[@]}"; do
            local comma=","
            [[ $i -eq $(( ${#LLAMA_PIDS[@]} - 1 )) ]] && comma=""
            printf '      {"pid": %s, "user": "%s", "vram": "%s", "model": "%s", "port": "%s", "uptime": "%s"}%s\n' \
                "${LLAMA_PIDS[$i]}" "${LLAMA_USERS[$i]}" "${LLAMA_VRAMS[$i]}" \
                "${LLAMA_MODELS[$i]}" "${LLAMA_PORTS[$i]}" "${LLAMA_UPTIMES[$i]}" "${comma}"
        done
    fi
    printf '    ]\n'
    printf '  },\n'

    # Reaper section
    printf '  "reaper": {\n'
    printf '    "status": "%s"' "${REAPER_STATUS}"
    if [[ "${REAPER_STATUS}" == "active" ]]; then
        printf ',\n    "interval_minutes": "%s"' "${REAPER_INTERVAL:-unknown}"
        printf ',\n    "max_idle_minutes": "%s"' "${REAPER_MAX_IDLE:-unknown}"
    fi
    printf '\n  }\n'

    printf '}\n'
}

# ---------- Compact Output ----------

render_compact() {
    local gpu_str="N/A"
    if [[ "${GPU_AVAILABLE}" == true ]]; then
        parse_gpu_info
        gpu_str="${GPU_UTIL}%"
    fi

    local vram_str="N/A"
    if [[ "${GPU_AVAILABLE}" == true ]]; then
        vram_str="${GPU_MEM_USED}/${GPU_MEM_TOTAL} MiB"
    fi

    local ollama_str
    if [[ "${OLLAMA_STATUS}" == "running" ]]; then
        ollama_str="$(c "${GREEN}" "●") ${OLLAMA_MODEL_COUNT} models"
    else
        ollama_str="$(c "${RED}" "●") down"
    fi

    local llama_str="${#LLAMA_PIDS[@]} processes"

    printf 'GPU: %s | VRAM: %s | Ollama: %s | llama.cpp: %s\n' \
        "${gpu_str}" "${vram_str}" "${ollama_str}" "${llama_str}"
}

# ---------- Main ----------

main() {
    # Gather all data upfront
    cache_gpu_data
    fetch_ollama
    find_llama_processes
    fetch_reaper

    case "${OUTPUT_MODE}" in
        json)
