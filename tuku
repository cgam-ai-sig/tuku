            printf '      {"pid": %s, "user": "%s", "vram": "%s", "model": "%s", "port": "%s", "uptime": "%s", "status": "%s"}%s\n' \
                "${DASH_LLAMA_PIDS[$i]}" "${DASH_LLAMA_USERS[$i]}" "${DASH_LLAMA_VRAMS[$i]}" \
                "${DASH_LLAMA_MODELS[$i]}" "${DASH_LLAMA_PORTS[$i]}" "${DASH_LLAMA_UPTIMES[$i]}" \
