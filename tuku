#!/usr/bin/env bash
set -euo pipefail

# tuku — GPU process management for shared servers running llama.cpp
#
# Merged binary: dashboard + reaper + diagnostics + management.
#
# Usage:
#   tuku                      → GPU dashboard
#   tuku reap                 → Reaper scan
#   tuku list                 → Diagnostic table with idle scores
#   tuku install [--system]   → Set up cron
#   tuku uninstall [--system] → Remove cron
#   tuku kill <PID> [PID...]  → Manual kill
#   tuku --help               → Full help
#   tuku --version            → Version

# ============================================================
# SECTION 1: CONSTANTS & DEFAULTS
# ============================================================

VERSION="0.1.0"
readonly SCRIPT_PATH="$(readlink -f "$0")"
readonly SCRIPT_NAME="$(basename "$0")"

# State directories (may be overridden in system mode)
USER_STATE_DIR="${HOME}/.local/state/tuku"
REAPER_STATE_DIR="${USER_STATE_DIR}/reaper"
readonly USER_LOG="${USER_STATE_DIR}/reaper.log"
readonly SYSTEM_LOG="/var/log/tuku.log"
readonly CRON_MARKER="# tuku-managed"
readonly SYSTEM_CRON_FILE="/etc/cron.d/tuku"

# Llama process name patterns (extended regex for grep -E)
readonly LLAMA_PATTERN='llama-server|llama-cli|llama-cpp|llama[.]cpp'

# Safety net: common non-llama executables to skip
readonly EXCLUDED_BASENAMES='grep|vim|less|tail|cat|python|bash|sh|editor|nano|emacs'

# Scoring threshold
readonly SCORE_KILL=8

# Reap defaults
MIN_AGE_MINUTES=60
MAX_IDLE_MINUTES=30
DRY_RUN=false
VERBOSE=false
FORCE=false
SYSTEM_MODE=false

# ============================================================
# SECTION 2: SHARED UTILITIES (used by both reap and dashboard)
# ============================================================

die() {
    printf '[%s] ERROR: %s\n' "$(date '+%H:%M:%S')" "$1" >&2
    exit "${2:-1}"
}

ensure_dirs() {
    mkdir -p "${REAPER_STATE_DIR}"
    if [[ "${SYSTEM_MODE}" == true ]]; then
        chmod 755 "${REAPER_STATE_DIR}" 2>/dev/null || true
    fi
}

# Get CLK_TCK for proc stat calculations (cached)
_CLK_TCK=""
get_clk_tck() {
    if [[ -z "${_CLK_TCK}" ]]; then
        _CLK_TCK="$(getconf CLK_TCK 2>/dev/null || echo 100)"
    fi
    echo "${_CLK_TCK}"
}

# Get system boot time in seconds since epoch (cached)
_BOOT_TIME=""
get_boot_time() {
    if [[ -z "${_BOOT_TIME}" ]]; then
        _BOOT_TIME="$(awk '/^btime / {print $2}' /proc/stat 2>/dev/null || echo 0)"
    fi
    echo "${_BOOT_TIME}"
}

# Format seconds into human-readable uptime (with day support)
format_uptime() {
    local seconds="$1"
    if [[ ${seconds} -lt 3600 ]]; then
        printf '%dm' "$((seconds / 60))"
    elif [[ ${seconds} -lt 86400 ]]; then
        printf '%dh %dm' "$((seconds / 3600))" "$(((seconds % 3600) / 60))"
    else
        printf '%dd %dh' "$((seconds / 86400))" "$(((seconds % 86400) / 3600))"
    fi
}

# Get process start time in epoch seconds from /proc/PID/stat
get_process_start_epoch() {
    local pid="$1"
    local stat_file="/proc/${pid}/stat"
    [[ -f "${stat_file}" ]] || return 1

    local stat_data
    stat_data="$(cat "${stat_file}" 2>/dev/null)" || return 1

    local after_comm="${stat_data##*) }"
    local starttime
    starttime="$(echo "${after_comm}" | awk '{print $20}')"
    [[ -n "${starttime}" ]] || return 1

    local clk_tck boot_time
    clk_tck="$(get_clk_tck)"
    boot_time="$(get_boot_time)"
    echo "$(( boot_time + starttime / clk_tck ))"
}

# Get process uptime in seconds
get_process_uptime_seconds() {
    local pid="$1"
    local start_epoch
    start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || start_epoch=0
    if [[ -n "${start_epoch}" ]] && [[ "${start_epoch}" -gt 0 ]]; then
        echo "$(( $(date +%s) - start_epoch ))"
    else
        echo "0"
    fi
}

# Find all llama.cpp processes. Returns lines of "PID USER COMMAND"
# In user mode (SYSTEM_MODE=false), filters to current user only.
# Matches LLAMA_PATTERN against the executable basename only.
find_llama_processes() {
    local current_user
    current_user="$(whoami)"

    # Pre-filter: single awk pass extracts matching lines only
    local filtered
    filtered="$(ps -eo pid=,user=,args= 2>/dev/null | awk -v pattern="${LLAMA_PATTERN}" -v excluded="${EXCLUDED_BASENAMES}" '
{
    # Extract the executable basename from the command (first word of args)
    cmd = $3
    n = split(cmd, parts, "/")
    exe = parts[n]

    # Skip excluded basenames
    if (match(exe, excluded)) next

    # Match against llama pattern
    if (match(exe, pattern)) print $0
}
')" || return 0

    [[ -z "${filtered}" ]] && return 0

    while IFS= read -r line; do
        [[ -z "${line}" ]] && continue

        local pid user args
        pid="$(echo "${line}" | awk '{print $1}')"
        user="$(echo "${line}" | awk '{print $2}')"
        args="$(echo "${line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        # Skip ourselves
        [[ "${pid}" == "$$" ]] && continue

        # In user mode, skip processes not owned by current user
        if [[ "${SYSTEM_MODE}" == false ]] && [[ "${user}" != "${current_user}" ]]; then
            continue
        fi

        echo "${pid} ${user} ${args}"
    done <<< "${filtered}"
}

# Get listen port for a process — try args first, then ss fallback
get_listen_port() {
    local pid="$1" cmdline="${2:-}"

    # Try --port from command line args first
    local port=""
    if [[ -n "${cmdline}" ]]; then
        port="$(echo "${cmdline}" | sed -n 's/.*--port[[:space:]]\+\([0-9]\+\).*/\1/p' | head -1)" || port=""
        # Also try -p (short flag)
        if [[ -z "${port}" ]]; then
            port="$(echo "${cmdline}" | sed -n 's/.*[[:space:]]-p[[:space:]]\+\([0-9]\+\).*/\1/p' | head -1)" || port=""
        fi
    fi

    # Fallback: use ss
    if [[ -z "${port}" ]]; then
        port="$(ss -tlnp 2>/dev/null | grep "pid=${pid}[,)]" | \
            sed -n 's/.*:\([0-9]\{1,\}\)[[:space:]].*/\1/p' | head -1)" || port=""
    fi
    echo "${port}"
}

# Get model name — try args first, then /v1/models API fallback
get_model_name() {
    local pid="$1" cmdline="$2" port="${3:-}"
    local model=""

    # Parse command line for -m or --model
    model="$(echo "${cmdline}" | sed -n 's/.*\(-m\|--model\)[[:space:]]\{1,\}\(\S\{1,\}\).*/\2/p' | head -1)" || model=""

    # API fallback if no model from args and port is known
    if [[ -z "${model}" ]] && [[ -n "${port}" ]]; then
        local api_response
        api_response="$(curl -s --connect-timeout 0.5 --max-time 1 "http://localhost:${port}/v1/models" 2>/dev/null)" || api_response=""
        if [[ -n "${api_response}" ]]; then
            model="$(printf '%s' "${api_response}" | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)" || model=""
        fi
    fi

    # Basename for cleaner display
    if [[ -n "${model}" ]]; then
        basename "${model}" 2>/dev/null || echo "${model}"
    else
        echo "unknown"
    fi
}

# Convert MiB to a clean GB string
mib_to_gb() {
    local mib="$1"
    local centi_gb=$(( mib * 100 / 1024 ))
    local whole_gb=$(( centi_gb / 100 ))
    local frac=$(( centi_gb % 100 ))
    if [[ ${whole_gb} -gt 10 ]]; then
        if [[ ${frac} -ge 50 ]]; then
            whole_gb=$(( whole_gb + 1 ))
        fi
        printf '%s GB' "${whole_gb}"
    elif [[ ${whole_gb} -eq 10 ]]; then
        local tenth=$(( (frac + 5) / 10 ))
        if [[ ${tenth} -ge 10 ]]; then
            printf '10 GB'
        else
            printf '%s.%s GB' "${whole_gb}" "${tenth}"
        fi
    else
        local tenth=$(( (frac + 5) / 10 ))
        if [[ ${tenth} -ge 10 ]]; then
            printf '%s GB' "$(( whole_gb + 1 ))"
        else
            printf '%s.%s GB' "${whole_gb}" "${tenth}"
        fi
    fi
}

# ============================================================
# SECTION 3: REAP-ONLY (never called by dashboard)
# ============================================================

# ---------- Logging ----------

log_file() {
    if [[ "${SYSTEM_MODE}" == true ]]; then
        echo "${SYSTEM_LOG}"
    else
        echo "${USER_LOG}"
    fi
}

log_msg() {
    local level="$1" msg="$2"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    local entry="[${ts}] ${level}: ${msg}"

    local lf
    lf="$(log_file)"
    mkdir -p "$(dirname "${lf}")"
    echo "${entry}" >> "${lf}" 2>/dev/null || true

    if [[ "${VERBOSE}" == true ]] || [[ "${level}" == "KILL" ]] || [[ "${level}" == "IDLE" ]] || [[ "${level}" == "ERROR" ]]; then
        echo "${entry}" >&2
    fi
}

# ---------- GPU scoring (reap-specific) ----------

# Get overall GPU power draw in watts (integer, rounded)
get_gpu_power_draw() {
    nvidia-smi --query-gpu=power.draw --format=csv,noheader,nounits 2>/dev/null | awk '{printf "%d", $1+0.5}'
}

# Returns "PID GPU_MEM_MIB" per line
get_gpu_processes() {
    nvidia-smi --query-compute-apps=pid,used_gpu_memory \
        --format=csv,noheader,nounits 2>/dev/null | \
        sed 's/,/ /g; s/^[[:space:]]*//; s/[[:space:]]*$//' || true
}

# Get GPU memory for a specific PID (returns MiB or empty)
get_gpu_mem_for_pid() {
    local target_pid="$1"
    local gpu_procs
    gpu_procs="$(get_gpu_processes)"
    [[ -z "${gpu_procs}" ]] && return 0

    while IFS= read -r line; do
        local pid mem
        pid="$(echo "${line}" | awk '{print $1}')"
        mem="$(echo "${line}" | awk '{print $2}')"
        if [[ "${pid}" == "${target_pid}" ]]; then
            echo "${mem}"
            return 0
        fi
    done <<< "${gpu_procs}"
}

# Check if a PID has active GPU SM utilization via pmon
get_gpu_utilization_for_pid() {
    local target_pid="$1"

    local pmon_output
    pmon_output="$(nvidia-smi pmon -c 1 -s u 2>/dev/null)" || pmon_output=""

    if [[ -n "${pmon_output}" ]]; then
        local sm_util
        sm_util="$(echo "${pmon_output}" | awk -v p="${target_pid}" '!/^#/ && $2 == p {print $4; exit}')"

        if [[ -n "${sm_util}" ]]; then
            if [[ "${sm_util}" == "-" ]] || [[ "${sm_util}" -eq 0 ]]; then
                echo "idle"
            else
                echo "active"
            fi
            return 0
        fi
    fi

    # Fallback: check overall GPU utilization as a heuristic
    local gpu_util
    gpu_util="$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -1)" || gpu_util=""

    if [[ -n "${gpu_util}" ]]; then
        gpu_util="$(echo "${gpu_util}" | tr -d '[:space:]')"
        if [[ "${gpu_util}" -eq 0 ]]; then
            echo "idle"
        else
            echo "unknown"
        fi
        return 0
    fi

    echo "unknown"
}

# ---------- CPU sampling ----------

get_cpu_time() {
    local pid="$1"
    local stat_file="/proc/${pid}/stat"
    [[ -f "${stat_file}" ]] || return 1

    local stat_data
    stat_data="$(cat "${stat_file}" 2>/dev/null)" || return 1

    local after_comm="${stat_data##*) }"

    local utime stime
    utime="$(echo "${after_comm}" | awk '{print $12}')"
    stime="$(echo "${after_comm}" | awk '{print $13}')"

    if [[ -n "${utime}" ]] && [[ -n "${stime}" ]]; then
        echo "$(( utime + stime ))"
    else
        return 1
    fi
}

save_cpu_sample() {
    local pid="$1" cpu_time="$2"
    local sample_file="${REAPER_STATE_DIR}/${pid}.cpu"
    echo "$(date +%s) ${cpu_time}" > "${sample_file}"
    chmod 644 "${sample_file}" 2>/dev/null || true
}

load_cpu_sample() {
    local pid="$1"
    local sample_file="${REAPER_STATE_DIR}/${pid}.cpu"
    if [[ -f "${sample_file}" ]]; then
        cat "${sample_file}" 2>/dev/null || true
    fi
}

# ---------- Network ----------

get_established_connections() {
    local pid="$1" port="$2"
    [[ -z "${port}" ]] && echo "0" && return 0

    local count
    count="$(ss -tnp "( sport = :${port} )" 2>/dev/null | \
        grep -c "ESTAB" 2>/dev/null)" || count=0
    echo "${count}"
}

# ---------- Alive timestamps ----------

write_alive_timestamp() {
    local pid="$1"
    local alive_file="${REAPER_STATE_DIR}/${pid}.alive"
    date +%s > "${alive_file}"
    chmod 644 "${alive_file}" 2>/dev/null || true
}

read_alive_timestamp() {
    local pid="$1"
    local alive_file="${REAPER_STATE_DIR}/${pid}.alive"
    if [[ -f "${alive_file}" ]]; then
        cat "${alive_file}" 2>/dev/null || true
    fi
}

# ---------- Idle scoring ----------

# Calculate idle score for a process.
# Prints "SCORE reason1; reason2; ..."
# When readonly=true, skips writing CPU samples and alive timestamps.
calculate_idle_score() {
    local pid="$1" user="$2" cmdline="$3"
    local is_readonly="${4:-false}"
    local score=0
    local reasons=()
    local now
    now="$(date +%s)"

    # Get overall GPU power draw
    local gpu_power
    gpu_power=$(get_gpu_power_draw)
    local gpu_power_active=false
    if [[ "${gpu_power}" -gt 100 ]]; then
        gpu_power_active=true
    fi

    # --- a. GPU compute activity ---
    local gpu_mem
    gpu_mem="$(get_gpu_mem_for_pid "${pid}")"
    if [[ -z "${gpu_mem}" ]] || [[ "${gpu_mem}" == "0" ]]; then
        if [[ "${gpu_power_active}" == true ]]; then
            reasons+=("no GPU memory, but power ${gpu_power}W > 100W — GPU active (+0)")
        else
            score=$((score + 3))
            reasons+=("no GPU memory, power ${gpu_power}W (+3)")
        fi
    else
        if [[ "${gpu_power_active}" == true ]]; then
            reasons+=("GPU mem: ${gpu_mem}MiB, power ${gpu_power}W > 100W — GPU active (+0)")
        else
            local gpu_util_status
            gpu_util_status="$(get_gpu_utilization_for_pid "${pid}")"
            if [[ "${gpu_util_status}" == "active" ]]; then
                reasons+=("GPU mem: ${gpu_mem}MiB, power ${gpu_power}W, actively computing (+0)")
            elif [[ "${gpu_util_status}" == "idle" ]]; then
                score=$((score + 3))
                reasons+=("GPU mem: ${gpu_mem}MiB, power ${gpu_power}W, utilization 0% — holding memory idle (+3)")
            else
                reasons+=("GPU mem: ${gpu_mem}MiB, power ${gpu_power}W, utilization unknown (+0)")
            fi
        fi
    fi

    # --- b. CPU time change (two-sample) ---
    local current_cpu
    current_cpu="$(get_cpu_time "${pid}" 2>/dev/null)" || current_cpu=""

    if [[ -n "${current_cpu}" ]]; then
        local prev_sample
        prev_sample="$(load_cpu_sample "${pid}")"

        if [[ -n "${prev_sample}" ]]; then
            local prev_epoch prev_cpu
            prev_epoch="$(echo "${prev_sample}" | awk '{print $1}')"
            prev_cpu="$(echo "${prev_sample}" | awk '{print $2}')"

            local time_delta=$((now - prev_epoch))
            if [[ ${time_delta} -ge 20 ]]; then
                local cpu_delta=$((current_cpu - prev_cpu))
                local tick_rate=0
                if [[ ${time_delta} -gt 0 ]]; then
                    tick_rate=$(( cpu_delta / time_delta ))
                fi
                if [[ ${cpu_delta} -le 0 ]] || [[ ${tick_rate} -lt 1 ]]; then
                    score=$((score + 3))
                    reasons+=("CPU near-idle: +${cpu_delta} ticks in ${time_delta}s (<1 tick/s) (+3)")
                else
                    reasons+=("CPU delta: +${cpu_delta} ticks in ${time_delta}s (+0)")
                fi
            else
                reasons+=("CPU sample too recent (${time_delta}s ago), skipping (+0)")
            fi
        else
            reasons+=("no previous CPU sample, first run (+0)")
        fi

        if [[ "${is_readonly}" != true ]]; then
            save_cpu_sample "${pid}" "${current_cpu}"
        fi
    else
        reasons+=("cannot read CPU time (+0)")
    fi

    # --- c. Network connections (for servers) ---
    local port
    port="$(get_listen_port "${pid}" "${cmdline}")"
    if [[ -n "${port}" ]]; then
        local conn_count
        conn_count="$(get_established_connections "${pid}" "${port}")"
        if [[ "${conn_count}" -eq 0 ]]; then
            score=$((score + 2))
            reasons+=("no connections on port ${port} (+2)")
        else
            reasons+=("${conn_count} connections on port ${port} (+0)")
        fi
    else
        reasons+=("not listening on any port (+0)")
    fi

    # --- d. Process age ---
    local start_epoch
    start_epoch="$(get_process_start_epoch "${pid}" 2>/dev/null)" || start_epoch=0
    if [[ ${start_epoch} -gt 0 ]]; then
        local age_seconds=$((now - start_epoch))
        local age_hours=$((age_seconds / 3600))
        local age_minutes=$((age_seconds / 60))

        if [[ ${age_hours} -ge 8 ]]; then
            score=$((score + 2))
            reasons+=("running > 8h ($(format_uptime "${age_seconds}")) (+2)")
        elif [[ ${age_hours} -ge 2 ]]; then
            score=$((score + 1))
            reasons+=("running > 2h ($(format_uptime "${age_seconds}")) (+1)")
        else
            reasons+=("uptime $(format_uptime "${age_seconds}") (+0)")
        fi

        if [[ ${age_minutes} -lt ${MIN_AGE_MINUTES} ]]; then
            score=0
            reasons+=("process younger than --min-age (${MIN_AGE_MINUTES}m), NOT eligible")
        fi
    fi

    local reason_str
    reason_str="$(IFS='; '; echo "${reasons[*]}")"
    echo "${score} ${reason_str}"
}

# ---------- Kill logic ----------

cleanup_pid_files() {
    local pid="$1"
    rm -f "${REAPER_STATE_DIR}/${pid}.alive" \
          "${REAPER_STATE_DIR}/${pid}.cpu" 2>/dev/null || true
}

kill_process() {
    local pid="$1" user="$2" model="$3" score="$4" reason="$5"

    if [[ "${DRY_RUN}" == true ]]; then
        log_msg "KILL(dry)" "PID=${pid} user=${user} model=${model} score=${score} reason=[${reason}]"
        echo "  [DRY-RUN] Would KILL PID ${pid} (${user}, ${model}, score=${score})"
        return 0
    fi

    log_msg "KILL" "PID=${pid} user=${user} model=${model} score=${score} reason=[${reason}]"
    echo "  KILLING PID ${pid} (${user}, ${model}, score=${score})"

    kill -TERM "${pid}" 2>/dev/null || true

    local waited=0
    while kill -0 "${pid}" 2>/dev/null && [[ ${waited} -lt 10 ]]; do
        sleep 1
        ((waited++))
    done

    if kill -0 "${pid}" 2>/dev/null; then
        log_msg "KILL" "PID=${pid} still alive after 10s, sending SIGKILL"
        kill -KILL "${pid}" 2>/dev/null || true
    fi

    cleanup_pid_files "${pid}"
}

cleanup_stale_reaper_files() {
    shopt -s nullglob
    local files=("${REAPER_STATE_DIR}"/*.alive "${REAPER_STATE_DIR}"/*.cpu)
    shopt -u nullglob

    for f in "${files[@]}"; do
        local basename_f
        basename_f="$(basename "${f}")"
        local pid="${basename_f%%.*}"
        if [[ -n "${pid}" ]] && ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
        fi
    done
}

# ---------- cmd_reap() — main reap orchestrator ----------

usage_reap() {
    cat <<'EOF'
Usage: tuku reap [OPTIONS]

Run idle process detection and cleanup.

Options:
  --min-age MINUTES   Minimum age before a process is eligible (default: 60)
  --max-idle MINUTES  Continuous idle time before killing (default: 30)
  --dry-run           Show what would happen without killing
  --verbose           Show detailed idle scoring for each process
  --force             Skip --max-idle duration check; kill immediately if idle
  --system            Manage ALL users' processes (for system cron)
  --help, -h          Show this help message

Scoring System:
  No GPU memory at all ................ +3
  GPU memory held, power <= 100W,
    utilization 0% .................... +3
  No CPU time change since last run ... +3
  No network connections (servers) .... +2
  Running > 2 hours ................... +1
  Running > 8 hours ................... +2
  GPU power > 100W .................... all GPU idle scoring blocked

  Score >= 8 and idle for >= --max-idle minutes: KILL

Examples:
  tuku reap                           # Run once in user mode
  tuku reap --dry-run --verbose       # See what would happen
  tuku reap --min-age 30 --max-idle 15  # Tighter thresholds
  tuku reap --force                   # Kill idle processes immediately
  tuku reap --system                  # System mode (all users)
EOF
    exit 0
}

cmd_reap() {
    # Parse reap-specific args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --min-age)
                [[ -n "${2:-}" ]] || die "--min-age requires a value"
                MIN_AGE_MINUTES="$2"; shift 2 ;;
            --max-idle)
                [[ -n "${2:-}" ]] || die "--max-idle requires a value"
                MAX_IDLE_MINUTES="$2"; shift 2 ;;
            --dry-run)   DRY_RUN=true; shift ;;
            --verbose)   VERBOSE=true; shift ;;
            --force)     FORCE=true; shift ;;
            --system)    SYSTEM_MODE=true; shift ;;
            --help|-h)   usage_reap ;;
            *)           die "Unknown reap option: $1. Run 'tuku reap --help'." ;;
        esac
    done

    # Override state directories for system mode
    if [[ "${SYSTEM_MODE}" == true ]]; then
        USER_STATE_DIR="/var/lib/tuku"
        REAPER_STATE_DIR="/var/lib/tuku/reaper"
    fi

    ensure_dirs

    local processes
    processes="$(find_llama_processes)"

    if [[ -z "${processes}" ]]; then
        [[ "${VERBOSE}" == true ]] && echo "No llama.cpp processes found."
        return 0
    fi

    local found_any=false
    local now
    now="$(date +%s)"

    while IFS= read -r proc_line; do
        [[ -z "${proc_line}" ]] && continue
        found_any=true

        local pid user cmdline
        pid="$(echo "${proc_line}" | awk '{print $1}')"
        user="$(echo "${proc_line}" | awk '{print $2}')"
        cmdline="$(echo "${proc_line}" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i; print ""}')"

        if ! kill -0 "${pid}" 2>/dev/null; then
            cleanup_pid_files "${pid}"
            continue
        fi

        local port
        port="$(get_listen_port "${pid}" "${cmdline}")"
        local model
        model="$(get_model_name "${pid}" "${cmdline}" "${port}")"

        local score_result score reason
        score_result="$(calculate_idle_score "${pid}" "${user}" "${cmdline}")"
        score="$(echo "${score_result}" | awk '{print $1}')"
        reason="$(echo "${score_result}" | cut -d' ' -f2-)"

        if [[ "${VERBOSE}" == true ]]; then
            local gpu_power_display
            gpu_power_display=$(get_gpu_power_draw)
            echo "  PID ${pid} (${user}, ${model}): score=${score}  [GPU power: ${gpu_power_display}W]"
            echo "    ${reason}"
        fi

        if [[ ${score} -ge ${SCORE_KILL} ]]; then
            if [[ "${FORCE}" == true ]]; then
                kill_process "${pid}" "${user}" "${model}" "${score}" "${reason}"
            else
                local alive_ts
                alive_ts="$(read_alive_timestamp "${pid}")"

                if [[ -z "${alive_ts}" ]]; then
                    write_alive_timestamp "${pid}"
                    if [[ "${VERBOSE}" == true ]]; then
                        echo "    → First idle detection, creating .alive timestamp, skipping"
                    fi
                    log_msg "IDLE" "PID=${pid} user=${user} model=${model} score=${score} reason=[first idle detection, benefit of the doubt]"
                else
                    local idle_since=$((now - alive_ts))
                    local max_idle_seconds=$((MAX_IDLE_MINUTES * 60))

                    if [[ ${idle_since} -ge ${max_idle_seconds} ]]; then
                        kill_process "${pid}" "${user}" "${model}" "${score}" "${reason}"
                    else
                        local remaining_minutes=$(( (max_idle_seconds - idle_since) / 60 ))
                        if [[ "${VERBOSE}" == true ]]; then
                            echo "    → Idle but within --max-idle window (last active $((idle_since / 60))m ago, ${remaining_minutes}m remaining)"
                        fi
                        log_msg "IDLE" "PID=${pid} user=${user} model=${model} score=${score} reason=[idle but within max-idle window, last active $((idle_since / 60))m ago]"
                    fi
                fi
            fi
        else
            if [[ ${score} -gt 0 ]]; then
                write_alive_timestamp "${pid}"
            fi
            log_msg "SKIP" "PID=${pid} user=${user} model=${model} score=${score} reason=[below threshold]"
        fi
    done <<< "${processes}"

    if [[ "${found_any}" == false ]]; then
        [[ "${VERBOSE}" == true ]] && echo "No llama.cpp processes found."
    fi

    cleanup_stale_reaper_files
}

